# ─── PostgreSQL (serengeti-iac data-tier) ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
GIS_DB_NAME=gisdb

# ─── Redis (serengeti-iac data-tier) ───
REDIS_PASSWORD=changeme

# ─── Elasticsearch (serengeti-iac data-tier) ───
ELASTIC_PASSWORD=changeme

# ─── JWT ───
GIS_JWT_SECRET=changeme-jwt-secret-key

# ─── MinIO (serengeti-iac data-tier) ───
GIS_MINIO_ENDPOINT=minio:9000
GIS_MINIO_ACCESS_KEY=minioadmin
GIS_MINIO_SECRET_KEY=minioadmin
GIS_MINIO_BUCKET=gis-imports

# ─── Kafka (serengeti-iac data-tier) ───
GIS_KAFKA_BOOTSTRAP=kafka:9092

# ─── Cloudflare / Domain (optional) ───
CF_GIS_HOST=gis.example.com
