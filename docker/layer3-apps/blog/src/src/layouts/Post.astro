---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const { title, description, pubDate, tags } = frontmatter;
---

<Base title={title} description={description}>
  <article>
    <h1>{title}</h1>
    <div class="meta">
      <time datetime={pubDate}>{new Date(pubDate).toLocaleDateString('ko-KR')}</time>
      {tags && tags.length > 0 && (
        <span class="tags">
          {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
        </span>
      )}
    </div>
    <slot />
  </article>
</Base>

<style>
  .meta {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .tag {
    color: var(--color-accent);
    margin-right: 0.5rem;
  }

  article :global(h2) { margin-top: 2rem; }
  article :global(h3) { margin-top: 1.5rem; }
</style>
