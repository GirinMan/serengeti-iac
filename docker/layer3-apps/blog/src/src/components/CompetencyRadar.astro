---
import { t } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const axes = [
  { key: "radar.llmApp" as const, value: 5 },
  { key: "radar.training" as const, value: 4 },
  { key: "radar.legal" as const, value: 5 },
  { key: "radar.serving" as const, value: 5 },
  { key: "radar.data" as const, value: 4 },
  { key: "radar.communication" as const, value: 4 },
];

const cx = 200;
const cy = 200;
const maxR = 150;
const levels = 5;
const n = axes.length;
const angleStep = (2 * Math.PI) / n;
const startAngle = -Math.PI / 2;

function polarToXY(angle: number, r: number): [number, number] {
  return [cx + r * Math.cos(angle), cy + r * Math.sin(angle)];
}

function polygonPoints(r: number): string {
  return axes
    .map((_, i) => {
      const angle = startAngle + i * angleStep;
      const [x, y] = polarToXY(angle, r);
      return `${x},${y}`;
    })
    .join(" ");
}

const dataPoints = axes.map((a, i) => {
  const angle = startAngle + i * angleStep;
  const r = (a.value / levels) * maxR;
  return polarToXY(angle, r);
});

const dataPolygon = dataPoints.map(([x, y]) => `${x},${y}`).join(" ");

const labelPositions = axes.map((a, i) => {
  const angle = startAngle + i * angleStep;
  const labelR = maxR + 32;
  const [x, y] = polarToXY(angle, labelR);
  let anchor = "middle";
  if (Math.cos(angle) < -0.1) anchor = "end";
  else if (Math.cos(angle) > 0.1) anchor = "start";
  let dy = "0.35em";
  if (Math.sin(angle) < -0.5) dy = "-0.2em";
  else if (Math.sin(angle) > 0.5) dy = "1em";
  return { x, y, anchor, dy, label: t(locale, a.key), value: a.value };
});
---

<div class="radar-container">
  <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" role="img" aria-label={t(locale, "radar.title")}>
    <!-- Grid polygons -->
    {[1, 2, 3, 4, 5].map((level) => (
      <polygon
        points={polygonPoints((level / levels) * maxR)}
        fill="none"
        stroke="var(--color-border)"
        stroke-width={level === 5 ? "1.5" : "0.8"}
        opacity={level === 5 ? "0.6" : "0.3"}
      />
    ))}

    <!-- Axis lines -->
    {axes.map((_, i) => {
      const angle = startAngle + i * angleStep;
      const [x2, y2] = polarToXY(angle, maxR);
      return (
        <line
          x1={cx}
          y1={cy}
          x2={x2}
          y2={y2}
          stroke="var(--color-border)"
          stroke-width="0.8"
          opacity="0.3"
        />
      );
    })}

    <!-- Data polygon -->
    <polygon
      points={dataPolygon}
      fill="var(--color-accent)"
      fill-opacity="0.15"
      stroke="var(--color-accent)"
      stroke-width="2"
    />

    <!-- Data points -->
    {dataPoints.map(([x, y]) => (
      <circle cx={x} cy={y} r="4" fill="var(--color-accent)" />
    ))}

    <!-- Labels -->
    {labelPositions.map((lp) => (
      <text
        x={lp.x}
        y={lp.y}
        text-anchor={lp.anchor}
        dy={lp.dy}
        class="radar-label"
        fill="var(--color-text-secondary)"
      >
        <tspan class="radar-label-name">{lp.label}</tspan>
        <tspan class="radar-label-value" dx="4" fill="var(--color-accent)">{lp.value}/{levels}</tspan>
      </text>
    ))}
  </svg>
</div>

<style>
  .radar-container {
    max-width: 480px;
    width: 100%;
    margin: 0 auto;
  }

  .radar-label {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
  }

  .radar-label-value {
    font-size: 11px;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .radar-container {
      max-width: 320px;
    }
    .radar-label {
      font-size: 10px;
    }
    .radar-label-value {
      font-size: 9px;
    }
  }
</style>
