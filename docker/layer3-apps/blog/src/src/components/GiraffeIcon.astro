---
/**
 * Tiny giraffe silhouette icon that shares the same source SVG as the
 * background watermark, so the site has a single coherent "giraffe" mark.
 *
 * Uses CSS `mask-image` so the icon is tinted with the caller's text color
 * (currentColor) and plays nicely with theme accents.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 16, class: className = "" } = Astro.props;
---

<span
  class:list={["giraffe-icon", className]}
  style={`--g-size: ${size}px;`}
  aria-hidden="true"
></span>

<style>
  .giraffe-icon {
    display: inline-block;
    width: var(--g-size);
    /* Simple-Cricut-Giraffe viewBox 800 x 600.7 ≈ 4:3 */
    height: calc(var(--g-size) * 0.75);
    background-color: currentColor;
    -webkit-mask: url('/images/svg/Simple-Cricut-Giraffe.svg') center / contain no-repeat;
    mask: url('/images/svg/Simple-Cricut-Giraffe.svg') center / contain no-repeat;
    vertical-align: -0.18em;
  }
</style>
