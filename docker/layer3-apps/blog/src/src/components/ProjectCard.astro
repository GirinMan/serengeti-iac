---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  slug?: string;
  image?: string;
  locale?: "en" | "ko";
}

const { title, description, tags = [], href, slug, image, locale } = Astro.props;
const hasLinks = href;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const prefix = locale === "en" ? `${base}/en` : base;
const detailUrl = slug ? `${prefix}/projects/${slug}` : undefined;
---

<article class="card-glow group relative rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden transition-all duration-300 hover:border-[var(--color-accent-dark)] hover:bg-[var(--color-bg-hover)] hover:-translate-y-1 hover:shadow-xl hover:shadow-[var(--color-accent)]/5 cursor-pointer">
  {image && (
    <div class="relative w-full aspect-video overflow-hidden border-b border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
      <img src={`${base}${image}`} alt={title} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-card)] via-transparent to-transparent opacity-40"></div>
    </div>
  )}
  <div class="p-6">
  <!-- Terminal-style project name -->
  <div class="flex items-center gap-2 mb-2">
    <span class="font-mono text-xs text-[var(--color-accent-dark)]" aria-hidden="true">▸</span>
    {detailUrl ? (
      <a href={detailUrl} class="text-lg font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-light)] transition-colors hover:underline after:absolute after:inset-0" style="font-family: var(--font-display);">
        {title}
      </a>
    ) : (
      <h3 class="text-lg font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-light)] transition-colors" style="font-family: var(--font-display);">
        {title}
      </h3>
    )}
  </div>

  <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="tag-pill rounded-full px-3 py-1 text-xs font-medium font-mono">
          {tag}
        </span>
      ))}
    </div>
  )}

  {hasLinks && (
    <div class="mt-4 flex gap-4 text-sm font-mono relative z-10">
      {href && (
        <a href={href} class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] hover:underline transition-colors" target="_blank" rel="noopener">
          demo &rarr;
        </a>
      )}
    </div>
  )}
  </div>
</article>
