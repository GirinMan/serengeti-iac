---
import { t, localePath, type Locale } from "../i18n";
import { getOssPrs } from "../data/opensource-prs";

interface Props {
  locale: Locale;
  /** Hide the outer section heading/icon when embedding inside another layout. */
  headingless?: boolean;
}

const { locale, headingless = false } = Astro.props;
const ossPrs = getOssPrs(locale);

const categoryConfig = {
  opensource: {
    icon: "🔓",
    label: t(locale, "achievements.cat.opensource"),
    color: "var(--color-terminal-green)",
    bgAlpha: "rgba(34, 197, 94, 0.12)",
  },
};
---

<div class="achv-group" data-achv-group="opensource">
  {!headingless && (
    <div class="achv-group-heading">
      <span
        class="achv-group-icon-badge"
        style={`background: ${categoryConfig.opensource.bgAlpha}; border-color: ${categoryConfig.opensource.color}30;`}
        aria-hidden="true"
      >
        {categoryConfig.opensource.icon}
      </span>
      <h2 class="achv-group-title">{categoryConfig.opensource.label}</h2>
      <span class="achv-group-count">{ossPrs.length} PRs</span>
    </div>
  )}

  {/* OSS Summary */}
  <div class="oss-summary" data-achv-category="opensource">
    <div class="oss-summary-grid">
      <div>
        <p class="oss-summary-label">{t(locale, "opensource.summary.repo")}</p>
        <a href="https://github.com/predibase/lorax" target="_blank" rel="noopener" class="oss-summary-value oss-summary-link">
          predibase/lorax
        </a>
      </div>
      <div>
        <p class="oss-summary-label">{t(locale, "opensource.summary.prs")}</p>
        <p class="oss-summary-value">4 PRs</p>
      </div>
      <div>
        <p class="oss-summary-label">{t(locale, "opensource.summary.period")}</p>
        <p class="oss-summary-value">2024.03 — 2024.10</p>
      </div>
      <div>
        <p class="oss-summary-label">{t(locale, "opensource.summary.theme")}</p>
        <p class="oss-summary-value">{t(locale, "opensource.summary.themeValue")}</p>
      </div>
    </div>
  </div>

  {/* PR Cards */}
  <div class="space-y-3" data-achv-category="opensource">
    {ossPrs.map((pr) => (
      <article class="oss-pr-card" data-achv-category="opensource">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
          <div class="flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-xs text-[var(--color-terminal-green)]">#{pr.number}</span>
              <h3 class="text-sm font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">
                {pr.title}
              </h3>
            </div>
            <p class="mt-1 text-xs text-[var(--color-text-secondary)] leading-relaxed">
              {pr.description}
            </p>
            <div class="mt-2 flex flex-wrap gap-1">
              {pr.tags.map((tag) => (
                <span class="tag-pill rounded-full px-2 py-0.5 text-xs font-mono">{tag}</span>
              ))}
            </div>
            <div class="mt-2 flex gap-3 text-xs font-mono">
              <a href={localePath(locale, `/opensource/${pr.slug}`)} class="text-[var(--color-accent-light)] hover:underline">
                {t(locale, "opensource.viewDetail")} &rarr;
              </a>
              <a href={pr.prUrl} target="_blank" rel="noopener" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent-light)]">
                {t(locale, "opensource.viewPr")} &nearr;
              </a>
            </div>
          </div>
          <div class="hidden md:block md:text-right shrink-0">
            <p class="font-mono text-xs text-[var(--color-terminal-green)]">{t(locale, "opensource.merged")}</p>
            <p class="font-mono text-xs text-[var(--color-text-muted)]">{pr.mergedDate}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</div>

<style>
  .achv-group { margin-top: 2rem; }

  .achv-group-heading {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }

  .achv-group-icon-badge {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid;
    font-size: 1rem;
  }

  .achv-group-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .achv-group-count {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    padding: 1px 6px;
    border-radius: 9999px;
    background: var(--color-bg-secondary);
  }

  .oss-summary {
    margin-bottom: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
  }

  .oss-summary-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    .oss-summary-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .oss-summary-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .oss-summary-value {
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .oss-summary-link {
    color: var(--color-accent-light);
    text-decoration: none;
    display: block;
  }

  .oss-summary-link:hover {
    text-decoration: underline;
  }

  .oss-pr-card {
    padding: 0.875rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition: all 0.2s;
  }

  .oss-pr-card:hover {
    border-color: var(--color-terminal-green, var(--color-border));
    background: var(--color-bg-hover);
  }
</style>
