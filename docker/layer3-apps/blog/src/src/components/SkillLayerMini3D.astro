---
/**
 * Compact 3D AI Infrastructure Stack for the Hero section.
 * Click navigates to /skills page.
 */
import { localePath } from "../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;
const heading = locale === "ko" ? "AI 역량 스택" : "AI Competency Stack";
const cta = locale === "ko" ? "상세 보기 \u2192" : "View Details \u2192";
---

<a href={localePath(locale, "/skills")} class="mini3d-link" aria-label={heading}>
  <div class="mini3d-wrap">
    <div class="mini3d-header">
      <span class="mini3d-title">{heading}</span>
    </div>
    <div class="mini3d-canvas-wrap" id="mini3d-canvas"></div>
    <div class="mini3d-cta"><span>{cta}</span></div>
  </div>
</a>

<script>
import * as THREE from 'three';

document.addEventListener('astro:page-load', () => {
  const wrap = document.getElementById('mini3d-canvas') as HTMLElement | null;
  if (!wrap) return;
  const old = wrap.querySelector('canvas');
  if (old) old.remove();

  const W = wrap.clientWidth, H = wrap.clientHeight || 260;

  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x08090c, 0.012);
  const cam = new THREE.PerspectiveCamera(32, W / H, 0.1, 200);
  const ren = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  ren.setSize(W, H);
  ren.setPixelRatio(Math.min(devicePixelRatio, 2));
  ren.setClearColor(0x000000, 0);
  ren.toneMapping = THREE.ACESFilmicToneMapping;
  ren.toneMappingExposure = 1.1;
  wrap.appendChild(ren.domElement);

  scene.add(new THREE.AmbientLight(0x485060, 0.7));
  const dL = new THREE.DirectionalLight(0xfff4e0, 1.2);
  dL.position.set(8, 16, 10); scene.add(dL);
  const fL = new THREE.DirectionalLight(0x7888b0, 0.4);
  fL.position.set(-8, 6, -5); scene.add(fL);

  function mkM(c: number, em: number, o?: Record<string, unknown>) {
    return new THREE.MeshPhysicalMaterial(Object.assign({
      color: c, emissive: em || 0, emissiveIntensity: 0.2,
      roughness: 0.28, metalness: 0.15, clearcoat: 0.8, clearcoatRoughness: 0.1,
    }, o || {}));
  }

  const LW = 5, LD = 4, GAP = 0.25, SUB_H = 0.55, SW = LW - 0.5, SD = LD - 0.5;

  interface SubDef { h: number; color: number; label: string; icon: number | string; }
  interface LayerDef {
    h: number; color: number; em: number; label: string; icon: number;
    subs?: SubDef[];
  }

  const layers: LayerDef[] = [
    { h: 0.7, color: 0x4a90d9, em: 0x152a48, label: 'Cross-cutting', icon: 1 },
    { h: 0.7, color: 0x3cbfa0, em: 0x0c2e22, label: 'Chips', icon: 2 },
    { h: 0.7, color: 0x8b7bd4, em: 0x1c1638, label: 'Infrastructure', icon: 3 },
    { h: 2.2, color: 0xe07a5f, em: 0x381510, label: 'Models', icon: 4, subs: [
      { h: SUB_H, color: 0xd4704f, label: 'Foundation', icon: '4.1' },
      { h: SUB_H, color: 0xc86040, label: 'Domain', icon: '4.2' },
      { h: SUB_H, color: 0xb85030, label: 'Evaluation', icon: '4.3' },
    ]},
    { h: 1.6, color: 0xe8a838, em: 0x382208, label: 'Applications', icon: 5, subs: [
      { h: SUB_H, color: 0xd89828, label: 'LLM Apps', icon: '5.1' },
      { h: SUB_H, color: 0xc88818, label: 'Agents', icon: '5.2' },
    ]},
  ];

  function drawIcon(ctx: CanvasRenderingContext2D, key: number | string, cx: number, cy: number, s: number) {
    ctx.save(); ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    if (key === 1) {
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 2;
      for (let i = 1; i <= 3; i++) { const rd = s * 0.12 + i * s * 0.065; ctx.beginPath(); ctx.arc(cx, cy, rd, -0.5, 0.5); ctx.stroke(); ctx.beginPath(); ctx.arc(cx, cy, rd, Math.PI - 0.5, Math.PI + 0.5); ctx.stroke(); }
      ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.moveTo(cx + s * 0.04, cy - s * 0.15); ctx.lineTo(cx - s * 0.08, cy + s * 0.02); ctx.lineTo(cx + s * 0.02, cy + s * 0.02); ctx.lineTo(cx - s * 0.04, cy + s * 0.15); ctx.lineTo(cx + s * 0.12, cy - s * 0.02); ctx.lineTo(cx + s * 0.04, cy - s * 0.02); ctx.closePath(); ctx.fill();
    } else if (key === 2) {
      const hs = s * 0.16; ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.strokeRect(cx - hs, cy - hs, hs * 2, hs * 2);
      ctx.fillStyle = '#fff'; const g2 = hs * 2 / 4;
      for (let i = 0; i < 4; i++) for (let j = 0; j < 4; j++) { ctx.beginPath(); ctx.arc(cx - hs + g2 * (i + 0.5), cy - hs + g2 * (j + 0.5), 1.2, 0, Math.PI * 2); ctx.fill(); }
    } else if (key === 3) {
      const rw = s * 0.22, rh = s * 0.3, rx = cx - rw / 2, ry = cy - rh / 2; ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.strokeRect(rx, ry, rw, rh);
      const un = 3, uh = rh / (un + 0.3);
      for (let i = 0; i < un; i++) { const uy = ry + uh * (i + 0.2); ctx.fillStyle = 'rgba(255,255,255,.4)'; ctx.fillRect(rx + 2, uy, rw - 4, uh * 0.4); ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(rx + rw - 4, uy + uh * 0.2, 1.2, 0, Math.PI * 2); ctx.fill(); }
    } else if (key === 4) {
      const cols = [[-s * 0.1, 3], [0, 4], [s * 0.1, 3]] as [number, number][];
      const nodes: { x: number; y: number }[][] = [];
      cols.forEach(([xo, cnt]) => { const ln: { x: number; y: number }[] = []; for (let i = 0; i < cnt; i++) ln.push({ x: cx + xo, y: cy + (i - (cnt - 1) / 2) * s * 0.07 }); nodes.push(ln); });
      ctx.strokeStyle = 'rgba(255,255,255,.5)'; ctx.lineWidth = 0.8;
      for (let l = 0; l < nodes.length - 1; l++) nodes[l].forEach(a => nodes[l + 1].forEach(b => { ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke(); }));
      nodes.forEach(l => l.forEach(n => { ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(n.x, n.y, 2, 0, Math.PI * 2); ctx.fill(); }));
    } else if (key === 5) {
      const bw = s * 0.26, bh = s * 0.2, bx = cx - bw / 2, by = cy - bh / 2; ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(bx + 2, by); ctx.lineTo(bx + bw - 2, by); ctx.quadraticCurveTo(bx + bw, by, bx + bw, by + 2); ctx.lineTo(bx + bw, by + bh - 2); ctx.quadraticCurveTo(bx + bw, by + bh, bx + bw - 2, by + bh); ctx.lineTo(bx + 2, by + bh); ctx.quadraticCurveTo(bx, by + bh, bx, by + bh - 2); ctx.lineTo(bx, by + 2); ctx.quadraticCurveTo(bx, by, bx + 2, by); ctx.stroke();
      ctx.fillStyle = 'rgba(255,255,255,.3)'; ctx.fillRect(bx, by, bw, bh * 0.18);
      ctx.fillStyle = 'rgba(255,255,255,.5)'; ctx.fillRect(bx + 4, by + bh * 0.32, bw * 0.35, 1.5); ctx.fillRect(bx + 4, by + bh * 0.5, bw * 0.25, 1.5);
    } else if (key === '4.1') {
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.arc(cx, cy, s * 0.12, 0, Math.PI * 2); ctx.stroke();
      for (let i = 0; i < 6; i++) { const a = Math.PI * 2 / 6 * i; ctx.beginPath(); ctx.moveTo(cx + Math.cos(a) * s * 0.12, cy + Math.sin(a) * s * 0.12); ctx.lineTo(cx + Math.cos(a) * s * 0.2, cy + Math.sin(a) * s * 0.2); ctx.stroke(); ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(cx + Math.cos(a) * s * 0.2, cy + Math.sin(a) * s * 0.2, 1.5, 0, Math.PI * 2); ctx.fill(); }
      ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(cx, cy, s * 0.03, 0, Math.PI * 2); ctx.fill();
    } else if (key === '4.2') {
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.moveTo(cx - s * 0.11, cy - s * 0.09); ctx.lineTo(cx + s * 0.11, cy - s * 0.09); ctx.lineTo(cx + s * 0.04, cy + s * 0.09); ctx.lineTo(cx - s * 0.04, cy + s * 0.09); ctx.closePath(); ctx.stroke();
      ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(cx, cy + s * 0.04, 2, 0, Math.PI * 2); ctx.fill();
    } else if (key === '4.3') {
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.2; const bw2 = s * 0.17, bh2 = s * 0.04;
      [-1, 0, 1].forEach(i => { const by2 = cy + i * s * 0.08; const w2 = bw2 - Math.abs(i) * s * 0.02; ctx.fillStyle = 'rgba(255,255,255,.25)'; ctx.fillRect(cx - w2 / 2, by2 - bh2 / 2, w2, bh2); ctx.strokeRect(cx - w2 / 2, by2 - bh2 / 2, w2, bh2); });
    } else if (key === '5.1') {
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(cx - s * 0.12 + 2, cy - s * 0.08); ctx.lineTo(cx + s * 0.12 - 2, cy - s * 0.08); ctx.quadraticCurveTo(cx + s * 0.12, cy - s * 0.08, cx + s * 0.12, cy - s * 0.08 + 2); ctx.lineTo(cx + s * 0.12, cy + s * 0.08 - 2); ctx.quadraticCurveTo(cx + s * 0.12, cy + s * 0.08, cx + s * 0.12 - 2, cy + s * 0.08); ctx.lineTo(cx - s * 0.12 + 2, cy + s * 0.08); ctx.quadraticCurveTo(cx - s * 0.12, cy + s * 0.08, cx - s * 0.12, cy + s * 0.08 - 2); ctx.lineTo(cx - s * 0.12, cy - s * 0.08 + 2); ctx.quadraticCurveTo(cx - s * 0.12, cy - s * 0.08, cx - s * 0.12 + 2, cy - s * 0.08); ctx.stroke();
      ctx.fillStyle = 'rgba(255,255,255,.5)'; ctx.fillRect(cx - s * 0.06, cy - s * 0.02, s * 0.1, 1.5); ctx.fillRect(cx - s * 0.06, cy + s * 0.02, s * 0.07, 1.5);
    } else if (key === '5.2') {
      const pts = [{ x: cx - s * 0.12, y: cy }, { x: cx, y: cy - s * 0.07 }, { x: cx, y: cy + s * 0.07 }, { x: cx + s * 0.12, y: cy }];
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.2; ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y); ctx.lineTo(pts[1].x, pts[1].y); ctx.moveTo(pts[0].x, pts[0].y); ctx.lineTo(pts[2].x, pts[2].y); ctx.moveTo(pts[1].x, pts[1].y); ctx.lineTo(pts[3].x, pts[3].y); ctx.moveTo(pts[2].x, pts[2].y); ctx.lineTo(pts[3].x, pts[3].y); ctx.stroke();
      pts.forEach(p => { ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2); ctx.fill(); });
    }
    ctx.restore();
  }

  // Create a face texture with icon + label
  function mkLabelTex(faceW: number, faceH: number, color: number, label: string, icon: number | string) {
    const cw = 512, ch = Math.round(512 * (faceH / faceW));
    const cv = document.createElement('canvas'); cv.width = cw; cv.height = ch;
    const c = cv.getContext('2d')!;
    const r = (color >> 16) & 255, g2 = (color >> 8) & 255, b = color & 255;
    c.fillStyle = `rgb(${r * 0.35 | 0},${g2 * 0.35 | 0},${b * 0.35 | 0})`;
    c.fillRect(0, 0, cw, ch);
    // Grid
    c.strokeStyle = `rgba(${r},${g2},${b},.06)`; c.lineWidth = 0.5;
    for (let x = 0; x < cw; x += 20) { c.beginPath(); c.moveTo(x, 0); c.lineTo(x, ch); c.stroke(); }
    for (let y = 0; y < ch; y += 20) { c.beginPath(); c.moveTo(0, y); c.lineTo(cw, y); c.stroke(); }
    // Icon + Label
    const fs = Math.min(ch * 0.5, cw * 0.08) | 0;
    const iconS = fs * 2;
    const iconX = cw * 0.22;
    drawIcon(c, icon, iconX, ch / 2, iconS);
    // Text to the right of icon
    const textX = iconX + iconS * 0.45 + cw * 0.04;
    c.fillStyle = '#ffffff'; c.font = `600 ${fs}px "Segoe UI","Apple SD Gothic Neo",sans-serif`;
    c.textAlign = 'left'; c.textBaseline = 'middle';
    c.fillText(label, textX, ch / 2);
    // Underline
    c.fillStyle = `rgba(${r},${g2},${b},.6)`;
    const tm = c.measureText(label);
    c.fillRect(textX, ch / 2 + fs * 0.45, tm.width, Math.max(1, ch * 0.015));
    const t = new THREE.CanvasTexture(cv); t.needsUpdate = true; return t;
  }

  const stack = new THREE.Group();
  let cy = 0;

  layers.forEach(L => {
    const g = new THREE.Group();
    if (L.subs) {
      const shellGeo = new THREE.BoxGeometry(LW, L.h, LD);
      // Shell front face with label
      const shellTex = mkLabelTex(LW, L.h, L.color, L.label, L.icon);
      const shellBase = mkM(L.color, L.em, { transparent: true, opacity: 0.12, depthWrite: false, side: THREE.DoubleSide });
      const shellFront = mkM(0xffffff, 0x000000, { transparent: true, opacity: 0.9, depthWrite: false, side: THREE.DoubleSide, map: shellTex, emissiveIntensity: 0 });
      // [+X, -X, +Y, -Y, +Z, -Z]
      const shell = new THREE.Mesh(shellGeo, [shellBase, shellBase, shellBase, shellBase, shellFront, shellBase]);
      shell.position.y = cy + L.h / 2;
      g.add(shell);
      const edge = new THREE.LineSegments(
        new THREE.EdgesGeometry(shellGeo),
        new THREE.LineBasicMaterial({ color: L.color, transparent: true, opacity: 0.15 })
      );
      edge.position.copy(shell.position); g.add(edge);

      const sg = 0.1;
      const tsh = L.subs.length * SUB_H + (L.subs.length - 1) * sg;
      let sy = cy + (L.h - tsh) / 2;
      L.subs.forEach(s => {
        const subGeo = new THREE.BoxGeometry(SW, s.h, SD);
        // Sub-block: label on -X (left face, visible from camera angle)
        const subTex = mkLabelTex(SD, s.h, s.color, s.label, s.icon);
        const subBase = mkM(s.color, L.em, { emissiveIntensity: 0.45 });
        const subSide = mkM(0xffffff, 0x000000, { emissiveIntensity: 0, map: subTex });
        const sm = new THREE.Mesh(subGeo, [subBase, subSide, subBase, subBase, subBase, subBase]);
        sm.position.y = sy + s.h / 2; g.add(sm);
        const se = new THREE.LineSegments(
          new THREE.EdgesGeometry(subGeo),
          new THREE.LineBasicMaterial({ color: new THREE.Color(L.color).offsetHSL(0, 0, 0.1), transparent: true, opacity: 0.15 })
        );
        se.position.copy(sm.position); g.add(se);
        sy += s.h + sg;
      });
    } else {
      const geo = new THREE.BoxGeometry(LW, L.h, LD);
      // Single block: label on +Z (front face)
      const tex = mkLabelTex(LW, L.h, L.color, L.label, L.icon);
      const base = mkM(L.color, L.em);
      const front = mkM(0xffffff, 0x000000, { emissiveIntensity: 0, map: tex });
      const m = new THREE.Mesh(geo, [base, base, base, base, front, base]);
      m.position.y = cy + L.h / 2; g.add(m);
      const e = new THREE.LineSegments(
        new THREE.EdgesGeometry(geo),
        new THREE.LineBasicMaterial({ color: L.color, transparent: true, opacity: 0.15 })
      );
      e.position.copy(m.position); g.add(e);
    }
    stack.add(g);
    cy += L.h + GAP;
  });

  scene.add(stack);

  // Camera position
  cam.position.set(-10, cy * 0.7, 12);
  cam.lookAt(new THREE.Vector3(0, cy * 0.38, 0));

  // Slow auto-rotate
  let t = 0;
  let animId = 0;
  function animate() {
    animId = requestAnimationFrame(animate);
    t += 0.003;
    stack.rotation.y = Math.sin(t) * 0.15 - 0.4;
    ren.render(scene, cam);
  }
  animate();

  // Resize
  function onResize() {
    const nw = wrap!.clientWidth, nh = wrap!.clientHeight || 260;
    cam.aspect = nw / nh; cam.updateProjectionMatrix(); ren.setSize(nw, nh);
  }
  window.addEventListener('resize', onResize);

  const cleanup = () => {
    cancelAnimationFrame(animId);
    ren.dispose();
    window.removeEventListener('resize', onResize);
    document.removeEventListener('astro:before-swap', cleanup);
  };
  document.addEventListener('astro:before-swap', cleanup);
});
</script>

<style>
  .mini3d-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s;
  }

  .mini3d-link:hover {
    transform: translateY(-2px);
  }

  .mini3d-wrap {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg-card);
    padding: 0.75rem 1rem;
    transition: all 0.3s;
    overflow: hidden;
  }

  .mini3d-link:hover .mini3d-wrap {
    border-color: var(--color-accent-dark);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), 0 0 15px rgba(212, 160, 106, 0.08);
  }

  .mini3d-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .mini3d-prefix {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-accent);
    opacity: 0.5;
  }

  .mini3d-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .mini3d-canvas-wrap {
    width: 100%;
    height: 260px;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .mini3d-canvas-wrap canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .mini3d-cta {
    margin-top: 0.5rem;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .mini3d-link:hover .mini3d-cta {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .mini3d-link:hover { transform: none; }
  }
</style>
