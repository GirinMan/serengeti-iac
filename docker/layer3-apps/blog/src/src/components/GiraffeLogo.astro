---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = "", size = 240 } = Astro.props;
---

<svg
  width={size}
  height={size * 1.4}
  viewBox="0 0 200 280"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={["giraffe-svg", className]}
  aria-hidden="true"
  role="img"
>
  <!-- Ossicones (horns) -->
  <circle cx="78" cy="18" r="5" fill="var(--color-accent)" opacity="0.8"/>
  <circle cx="112" cy="18" r="5" fill="var(--color-accent)" opacity="0.8"/>
  <line x1="78" y1="23" x2="78" y2="38" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round"/>
  <line x1="112" y1="23" x2="112" y2="38" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round"/>

  <!-- Head -->
  <rect x="65" y="32" width="60" height="42" rx="16" fill="var(--color-accent)" opacity="0.12" stroke="var(--color-accent)" stroke-width="1.5"/>

  <!-- Eyes -->
  <circle cx="82" cy="50" r="3.5" fill="var(--color-accent)"/>
  <circle cx="108" cy="50" r="3.5" fill="var(--color-accent)"/>
  <circle cx="83.5" cy="49" r="1.2" fill="var(--color-bg-primary)"/>
  <circle cx="109.5" cy="49" r="1.2" fill="var(--color-bg-primary)"/>

  <!-- Smile -->
  <path d="M88 60 Q95 67 102 60" stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round"/>

  <!-- Ears -->
  <path d="M65 42 L52 35 L62 48" fill="var(--color-accent)" opacity="0.15" stroke="var(--color-accent)" stroke-width="1"/>
  <path d="M125 42 L138 35 L128 48" fill="var(--color-accent)" opacity="0.15" stroke="var(--color-accent)" stroke-width="1"/>

  <!-- Neck -->
  <path d="M82 74 L82 170 Q82 176 88 176 L102 176 Q108 176 108 170 L108 74" fill="var(--color-accent)" opacity="0.06" stroke="var(--color-accent)" stroke-width="1.5"/>

  <!-- Spots on neck -->
  <ellipse cx="90" cy="95" rx="6" ry="5" fill="var(--color-accent)" opacity="0.12"/>
  <ellipse cx="102" cy="110" rx="5" ry="6" fill="var(--color-accent)" opacity="0.12"/>
  <ellipse cx="88" cy="128" rx="7" ry="5" fill="var(--color-accent)" opacity="0.12"/>
  <ellipse cx="100" cy="148" rx="5" ry="6" fill="var(--color-accent)" opacity="0.12"/>
  <ellipse cx="92" cy="164" rx="6" ry="4" fill="var(--color-accent)" opacity="0.12"/>

  <!-- Body -->
  <rect x="58" y="170" width="74" height="52" rx="12" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1.5"/>

  <!-- Spots on body -->
  <ellipse cx="78" cy="188" rx="8" ry="7" fill="var(--color-accent)" opacity="0.1"/>
  <ellipse cx="112" cy="192" rx="7" ry="8" fill="var(--color-accent)" opacity="0.1"/>
  <ellipse cx="95" cy="205" rx="9" ry="6" fill="var(--color-accent)" opacity="0.1"/>

  <!-- Code on body — developer touch -->
  <text x="72" y="193" fill="var(--color-accent)" opacity="0.35" font-family="monospace" font-size="8">{"{ }"}</text>
  <text x="102" y="208" fill="var(--color-accent)" opacity="0.35" font-family="monospace" font-size="7">AI</text>

  <!-- Front legs -->
  <line x1="74" y1="222" x2="74" y2="258" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="90" y1="222" x2="90" y2="258" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round"/>

  <!-- Back legs -->
  <line x1="100" y1="222" x2="100" y2="258" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="116" y1="222" x2="116" y2="258" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round"/>

  <!-- Hooves -->
  <rect x="69" y="255" width="10" height="6" rx="3" fill="var(--color-accent)" opacity="0.6"/>
  <rect x="85" y="255" width="10" height="6" rx="3" fill="var(--color-accent)" opacity="0.6"/>
  <rect x="95" y="255" width="10" height="6" rx="3" fill="var(--color-accent)" opacity="0.6"/>
  <rect x="111" y="255" width="10" height="6" rx="3" fill="var(--color-accent)" opacity="0.6"/>

  <!-- Tail -->
  <path d="M132 180 Q145 175 148 185 Q150 192 142 190" stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <circle cx="142" cy="190" r="3" fill="var(--color-accent)" opacity="0.4"/>
</svg>

<style>
  .giraffe-svg {
    filter: drop-shadow(0 0 20px var(--color-accent-glow));
    transition: transform 0.3s ease;
  }
  .giraffe-svg:hover {
    transform: scale(1.02);
  }
</style>
