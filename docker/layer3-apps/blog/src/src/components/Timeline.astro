---
interface Props {
  title: string;
  organization: string;
  period: string;
  description?: string;
  current?: boolean;
}

const { title, organization, period, description, current = false } = Astro.props;
---

<div class="timeline-item relative pl-8 pb-8 last:pb-0 group">
  <!-- Vertical line -->
  <div class="absolute left-[7px] top-2 h-full w-px bg-[var(--color-border)] group-last:hidden"></div>
  <!-- Dot with pulse for current role -->
  <div class:list={[
    "absolute left-0 top-2 h-[15px] w-[15px] rounded-full border-2 transition-colors duration-200",
    current
      ? "border-[var(--color-accent)] bg-[var(--color-accent)]/20"
      : "border-[var(--color-border)] bg-[var(--color-bg-secondary)]",
  ]}>
    {current && (
      <span class="absolute inset-0 rounded-full border-2 border-[var(--color-accent)] animate-ping opacity-30" aria-hidden="true"></span>
    )}
  </div>
  <!-- Content -->
  <div>
    <p class="text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)]">
      {period}
    </p>
    <h3 class="mt-1 text-base font-semibold text-[var(--color-text-primary)]">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-accent-light)]">{organization}</p>
    {description && (
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
        {description}
      </p>
    )}
  </div>
</div>
