  /* Mobile */
  @media (max-width: 860px) {
    .s3d-canvas-wrap { height: 350px; }
    .s3d-panel {
      flex-direction: column;
      overflow-y: auto;
      max-height: 300px;
    }
    .s3d-li {
      border-right: none;
      border-bottom: none;
      border-bottom: 1px solid rgba(255,255,255,.03);
    }
    .s3d-li:last-child { border-bottom: none; }
    :global(.s3d-li.on) { border-bottom: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .s3d-li-sb { transition: none; }
  }
</style>
