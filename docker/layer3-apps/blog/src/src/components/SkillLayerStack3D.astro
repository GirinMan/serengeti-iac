  }

  .s3d-li:last-child { border-right: none; }

  .s3d-li:hover, :global(.s3d-li.on) { background: rgba(255,255,255,.02); }

  .s3d-li-hd { display: flex; align-items: center; gap: 6px; }

  .s3d-li-dot {
    width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    transition: box-shadow 0.3s;
  }

  :global(.s3d-li.on) .s3d-li-dot { box-shadow: 0 0 10px 2px currentColor; }

  .s3d-li-num {
    font-size: 8px; letter-spacing: 1px; font-weight: 600; opacity: 0.3;
    font-family: var(--font-mono);
  }

  :global(.s3d-li.on) .s3d-li-num { opacity: 0.6; }

  .s3d-li-tt { font-size: 12px; font-weight: 600; letter-spacing: -0.2px; white-space: nowrap; }

  .s3d-li-ds { font-size: 9.5px; opacity: 0.3; margin-top: 3px; line-height: 1.4; }
  :global(.s3d-li.on) .s3d-li-ds { opacity: 0.5; }

  /* Sub-layer expand */
  .s3d-li-sb {
    max-height: 0; overflow: hidden; transition: max-height 0.35s ease;
  }

  :global(.s3d-li.on) .s3d-li-sb { max-height: 300px; }

  .s3d-si {
    margin: 4px 0; padding: 6px 8px; border-radius: 5px;
    border: 1px solid rgba(255,255,255,.03);
  }

  .s3d-si-sn { font-size: 7px; letter-spacing: 1px; opacity: 0.25; font-weight: 600; font-family: var(--font-mono); }
  .s3d-si-st { font-size: 10px; font-weight: 600; margin-top: 1px; }
  .s3d-si-tg { display: flex; gap: 3px; margin-top: 4px; flex-wrap: wrap; }
  .s3d-si-tg span {
    font-size: 7px; letter-spacing: 0.5px; font-weight: 600;
    padding: 1px 5px; border-radius: 3px;
    font-family: var(--font-mono);
  }

  /* Color classes */
  .c1 .s3d-li-dot { color: #4a90d9; background: #4a90d9; }
  .c1 .s3d-li-tt { color: #7ab8f0; }
  :global(.c1.on) { border-bottom-color: #4a90d9; }

  .c2 .s3d-li-dot { color: #3cbfa0; background: #3cbfa0; }
  .c2 .s3d-li-tt { color: #6ee0be; }
  :global(.c2.on) { border-bottom-color: #3cbfa0; }

  .c3 .s3d-li-dot { color: #8b7bd4; background: #8b7bd4; }
  .c3 .s3d-li-tt { color: #b0a4e8; }
  :global(.c3.on) { border-bottom-color: #8b7bd4; }

  .c4 .s3d-li-dot { color: #e07a5f; background: #e07a5f; }
  .c4 .s3d-li-tt { color: #f0a088; }
  :global(.c4.on) { border-bottom-color: #e07a5f; }
  .c4 .s3d-si { background: rgba(224,122,95,.03); }
  .c4 .s3d-si-st { color: #efa08a; }
  .c4 .s3d-si-tg span { background: rgba(224,122,95,.1); color: #e07a5f; }

  .c5 .s3d-li-dot { color: #e8a838; background: #e8a838; }
  .c5 .s3d-li-tt { color: #f0c868; }
  :global(.c5.on) { border-bottom-color: #e8a838; }
  .c5 .s3d-si { background: rgba(232,168,56,.03); }
  .c5 .s3d-si-st { color: #f0c060; }
  .c5 .s3d-si-tg span { background: rgba(232,168,56,.1); color: #e8a838; }

  /* Divider & Show All */
  .s3d-divider {
    display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0 1rem;
  }

  .s3d-divider-line { flex: 1; height: 1px; background: var(--color-border); }

  .s3d-divider-label {
    font-family: var(--font-mono); font-size: 0.6875rem;
    color: var(--color-text-muted); white-space: nowrap;
  }

  .s3d-show-all {
    display: none; margin: 0 auto 1rem; padding: 0.5rem 1.5rem;
    border-radius: 9999px; border: 1px solid var(--color-border);
    background: var(--color-bg-card); color: var(--color-text-muted);
    font-family: var(--font-mono); font-size: 0.75rem; cursor: pointer;
    transition: all 0.2s;
  }

  .s3d-show-all:hover {
    border-color: var(--color-accent); color: var(--color-accent-light);
  }

  /* Desktop 2-column: hide divider */
  @media (min-width: 1200px) {
    .s3d-divider { display: none; }
    .s3d-show-all { display: none !important; }
