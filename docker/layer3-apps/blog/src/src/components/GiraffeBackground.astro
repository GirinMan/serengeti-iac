---
/**
 * 페이지 전역 우측 하단 배경 워터마크.
 *
 * 기린 실루엣은 public/images/svg/Simple-Cricut-Giraffe.svg 를
 * CSS `mask-image` 로 덮어서 accent 컬러로 tint 한다.
 * 이렇게 하면 원본 SVG 색을 건드리지 않고도 사이트 테마와 항상 어울린다.
 */
---

<div class="giraffe-bg" aria-hidden="true"></div>

<style>
  .giraffe-bg {
    position: fixed;
    bottom: -6%;
    right: -11%;
    /* 이전 피드백(가로·세로 절반) 대비 1.5배로 키운 값. */
    width: 82.5vw;
    max-width: 1170px;
    min-width: 540px;
    aspect-ratio: 800 / 600.7; /* Simple-Cricut-Giraffe viewBox 와 일치 */
    pointer-events: none;
    z-index: 0;

    /* 실루엣 전체를 단일 accent 컬러로 채운다 */
    background-color: var(--color-accent);

    -webkit-mask-image: url('/images/svg/Simple-Cricut-Giraffe.svg');
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: contain;
    mask-image: url('/images/svg/Simple-Cricut-Giraffe.svg');
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;

    opacity: 0.22;
    animation: giraffeDrift 22s ease-in-out infinite;
    will-change: transform, opacity;
  }

  @keyframes giraffeDrift {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.22;
    }
    33% {
      transform: translateY(-10px) rotate(0.3deg);
      opacity: 0.26;
    }
    66% {
      transform: translateY(-5px) rotate(-0.2deg);
      opacity: 0.24;
    }
  }

  /* 모바일: 가로 폭은 올리되 opacity 는 낮춰서 가독성 방해 최소화 */
  @media (max-width: 768px) {
    .giraffe-bg {
      width: 108vw;
      right: -21%;
      bottom: -5%;
      opacity: 0.15;
    }
  }

  @media (max-width: 480px) {
    .giraffe-bg {
      width: 135vw;
      right: -31%;
      opacity: 0.13;
    }
  }

  /* 접근성: 모션 감소 설정 존중 */
  @media (prefers-reduced-motion: reduce) {
    .giraffe-bg {
      animation: none;
      opacity: 0.2;
    }
  }
</style>
