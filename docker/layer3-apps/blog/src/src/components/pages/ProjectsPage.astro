---
import Layout from "../Layout.astro";
import ProjectCard from "../ProjectCard.astro";
import { getCollection } from "astro:content";
import { t } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

// Content fetching: ko fetches ko first then falls back to en; en fetches only en
const allProjects = await (async () => {
  if (locale === "ko") {
    const koProjects = await getCollection("projects", (p) => p.data.locale === "ko");
    const enProjects = await getCollection("projects", (p) => p.data.locale === "en");
    return koProjects.length > 0 ? koProjects : enProjects;
  }
  return await getCollection("projects", (p) => p.data.locale === "en");
})();

// Parse start date from period string for chronological sorting
function parseStartDate(period?: string): number {
  if (!period) return 0;
  // Handle formats: "2024.04", "2024 Q1", "2024.04 —", "2023.09 — 현재"
  const m = period.match(/(\d{4})(?:\.(\d{2})|[\s.]?Q(\d))?/);
  if (!m) return 0;
  const year = parseInt(m[1]);
  if (m[2]) return year * 100 + parseInt(m[2]);
  if (m[3]) return year * 100 + (parseInt(m[3]) - 1) * 3 + 1;
  return year * 100 + 1;
}

// Sort by start date descending (newest first)
const projects = allProjects.sort((a, b) => parseStartDate(b.data.period) - parseStartDate(a.data.period));

// Group by start year
const yearFallback = locale === "ko" ? "기타" : "Other";
function getStartYear(period?: string): string {
  const m = period?.match(/(\d{4})/);
  return m ? m[1] : yearFallback;
}

const yearGroups: { year: string; projects: typeof projects }[] = [];
const seen = new Set<string>();
for (const p of projects) {
  const year = getStartYear(p.data.period);
  if (!seen.has(year)) {
    seen.add(year);
    yearGroups.push({ year, projects: [] });
  }
  yearGroups.find((g) => g.year === year)!.projects.push(p);
}

const filters = locale === "ko"
  ? [
      { id: "all", label: "전체" },
      { id: "agent", label: "에이전트 & 워크플로우", keywords: ["에이전트", "워크플로우", "agent", "langgraph", "workflow", "추론"] },
      { id: "legal", label: "Legal AI", keywords: ["legal", "계약", "contract", "법률", "hwp", "word plugin"] },
      { id: "training", label: "모델 학습", keywords: ["학습", "sft", "dpo", "lora", "peft", "양자화", "quantization", "training", "hyperclova"] },
      { id: "eval", label: "평가", keywords: ["평가", "evaluation", "llm-as-judge", "품질", "quality"] },
      { id: "infra", label: "인프라", keywords: ["인프라", "infrastructure", "vllm", "서빙", "serving", "gpu", "litellm", "정부 사업"] },
      { id: "oss", label: "오픈소스", keywords: ["오픈소스", "open source", "rust"] },
    ]
  : [
      { id: "all", label: "All" },
      { id: "agent", label: "Agent & Workflow", keywords: ["agent", "langgraph", "workflow", "reasoning", "multi-hop"] },
      { id: "legal", label: "Legal AI", keywords: ["legal", "contract", "hwp", "word plugin"] },
      { id: "training", label: "Model Training", keywords: ["training", "sft", "dpo", "lora", "peft", "quantization", "hyperclova"] },
      { id: "eval", label: "Evaluation", keywords: ["evaluation", "llm-as-judge", "quality", "metrics"] },
      { id: "infra", label: "Infrastructure", keywords: ["infrastructure", "vllm", "serving", "gpu", "litellm", "government program"] },
      { id: "oss", label: "Open Source", keywords: ["open source", "rust"] },
    ];

const layoutDescription = locale === "ko"
  ? "AI/ML 프로젝트 및 엔지니어링 작업물."
  : "Featured AI/ML projects and engineering work.";

const filterAriaLabel = locale === "ko"
  ? "프로젝트 카테고리 필터"
  : "Project category filter";

const emptyText = locale === "ko"
  ? "해당 카테고리의 프로젝트가 없습니다."
  : "No projects in this category.";

const countSuffix = locale === "ko" ? "개 프로젝트" : " projects";

function formatCount(n: number): string {
  return locale === "ko" ? `${n}개 프로젝트` : `${n} projects`;
}

function getSlug(project: typeof projects[number]): string {
  return locale === "en" ? project.id.replace(/-en$/, "") : project.id;
}
---

<Layout title={t(locale, "projects.title")} description={layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16" >
    <div class="flex items-center gap-3 mb-2">
      <span class="font-mono text-sm text-[var(--color-accent)]" aria-hidden="true">##</span>
      <h1 class="text-3xl font-bold" style="font-family: var(--font-display);">{t(locale, "projects.heading")}</h1>
    </div>
    <p class="mt-3 text-base text-[var(--color-text-secondary)] max-w-2xl ml-7">
      {t(locale, "projects.desc")}
    </p>

    <!-- Filter Tabs -->
    <div class="mt-8 flex flex-wrap gap-2 ml-7" role="tablist" aria-label={filterAriaLabel}>
      {filters.map((f) => (
        <button
          role="tab"
          aria-selected={f.id === "all" ? "true" : "false"}
          data-filter={f.id}
          data-keywords={f.id !== "all" ? JSON.stringify(f.keywords) : ""}
          class:list={[
            "project-filter-tab font-mono text-xs px-3 py-1.5 rounded-full border transition-all duration-200",
            f.id === "all"
              ? "border-[var(--color-accent)] bg-[var(--color-accent)]/15 text-[var(--color-accent)]"
              : "border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-accent-dark)] hover:text-[var(--color-text-secondary)]",
          ]}
        >
          {f.label}
        </button>
      ))}
    </div>

    <!-- Timeline-grouped Project Grid -->
    <div id="project-timeline" class="mt-10" data-count-suffix={countSuffix}>
      {yearGroups.map((group, groupIdx) => (
        <div class="year-group" data-year={group.year}>
          <!-- Year Header -->
          <button class="year-header flex items-center gap-3 mt-10 mb-6 first:mt-0 w-full text-left cursor-pointer group/yr" data-year-toggle aria-expanded="true">
            <div class="flex items-center gap-2">
              <span class="inline-block w-3 h-3 rounded-full bg-[var(--color-accent)]"></span>
              <span class="font-mono text-lg font-bold text-[var(--color-accent)]">{group.year}</span>
            </div>
            <div class="flex-1 h-px bg-[var(--color-border)]"></div>
            <span class="font-mono text-xs text-[var(--color-text-muted)]" data-year-count>{formatCount(group.projects.length)}</span>
            <svg class="year-chevron w-4 h-4 text-[var(--color-text-muted)] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Project Cards -->
          <div class="year-cards grid gap-6 md:grid-cols-2 ml-5 pl-5 border-l-2 border-[var(--color-border)]">
            {group.projects.map((project) => (
              <div class="project-card-wrapper relative" data-tags={project.data.tags.map((t: string) => t.toLowerCase()).join(",")}>
                {/* Period badge */}
                <div class="absolute -left-[calc(1.25rem+1.5px)] top-4 w-2.5 h-2.5 rounded-full bg-[var(--color-bg-secondary)] border-2 border-[var(--color-accent-dark)] z-10"></div>
                <div class="mb-2 flex items-center gap-2">
                  <span class="font-mono text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-secondary)] px-2 py-0.5 rounded border border-[var(--color-border)]">
                    {project.data.period}
                  </span>
                  {project.data.organization && (
                    <span class="font-mono text-xs text-[var(--color-accent-dark)]">
                      @ {project.data.organization}
                    </span>
                  )}
                </div>
                <ProjectCard
                  title={project.data.title}
                  description={project.data.description}
                  tags={project.data.tags}
                  href={project.data.href}
                  slug={getSlug(project)}
                  image={project.data.image}
                  locale={locale}
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <p id="project-empty" class="hidden mt-12 text-center text-sm text-[var(--color-text-muted)] font-mono">
      {emptyText}
    </p>
  </section>
</Layout>

<style>
  .project-card-wrapper {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .project-card-wrapper.filter-hidden {
    display: none;
  }

  .year-group.filter-hidden {
    display: none;
  }

  .year-cards.year-collapsed {
    display: none;
  }

  .year-chevron {
    transition: transform 0.2s ease;
  }

  [data-year-toggle][aria-expanded="false"] .year-chevron {
    transform: rotate(-90deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card-wrapper {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>(".project-filter-tab");
    const cards = document.querySelectorAll<HTMLElement>(".project-card-wrapper");
    const yearGroups = document.querySelectorAll<HTMLElement>(".year-group");
    const empty = document.getElementById("project-empty");
    const timeline = document.getElementById("project-timeline");
    const countSuffix = timeline?.dataset.countSuffix || " projects";
    if (!tabs.length || !cards.length) return;

    function formatCount(n: number): string {
      return `${n}${countSuffix}`;
    }

    // Year collapse/expand toggle
    const yearToggles = document.querySelectorAll<HTMLButtonElement>("[data-year-toggle]");
    yearToggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        const group = btn.closest(".year-group");
        const cards = group?.querySelector(".year-cards");
        if (!cards) return;
        const isExpanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", isExpanded ? "false" : "true");
        cards.classList.toggle("year-collapsed", isExpanded);
      });
    });

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const filterId = tab.dataset.filter;
        const keywordsRaw = tab.dataset.keywords;

        // Update active tab styles
        tabs.forEach((t) => {
          t.setAttribute("aria-selected", "false");
          t.classList.remove("border-[var(--color-accent)]", "bg-[var(--color-accent)]/15", "text-[var(--color-accent)]");
          t.classList.add("border-[var(--color-border)]", "text-[var(--color-text-muted)]");
        });
        tab.setAttribute("aria-selected", "true");
        tab.classList.add("border-[var(--color-accent)]", "bg-[var(--color-accent)]/15", "text-[var(--color-accent)]");
        tab.classList.remove("border-[var(--color-border)]", "text-[var(--color-text-muted)]");

        // Expand all year groups when filtering
        if (filterId !== "all") {
          yearToggles.forEach((btn) => {
            btn.setAttribute("aria-expanded", "true");
            const cards = btn.closest(".year-group")?.querySelector(".year-cards");
            cards?.classList.remove("year-collapsed");
          });
        }

        // Filter cards
        let visibleCount = 0;
        const keywords: string[] = keywordsRaw ? JSON.parse(keywordsRaw) : [];

        cards.forEach((card) => {
          const tags = card.dataset.tags || "";
          const show = filterId === "all" || keywords.some((kw) => tags.includes(kw));

          if (show) {
            card.classList.remove("filter-hidden");
            visibleCount++;
          } else {
            card.classList.add("filter-hidden");
          }
        });

        // Hide year groups with no visible cards
        yearGroups.forEach((group) => {
          const visibleInGroup = group.querySelectorAll(".project-card-wrapper:not(.filter-hidden)");
          group.classList.toggle("filter-hidden", visibleInGroup.length === 0);
          const countEl = group.querySelector("[data-year-count]");
          if (countEl) {
            if (filterId === "all") {
              const totalInGroup = group.querySelectorAll(".project-card-wrapper").length;
              countEl.textContent = formatCount(totalInGroup);
            } else {
              countEl.textContent = formatCount(visibleInGroup.length);
            }
          }
        });

        // Empty state
        if (empty) {
          empty.classList.toggle("hidden", visibleCount > 0);
        }
      });
    });
  });
</script>
