---
import Layout from "../Layout.astro";
import Hero from "../Hero.astro";
import { getCollection } from "astro:content";
import profile from "../../data/profile.json";
import profileKo from "../../data/profile.ko.json";
import { t, localePath } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const primaryProjects = await getCollection("projects", (p) => p.data.locale === locale);
const fallbackProjects = await getCollection("projects", (p) => p.data.locale === (locale === "ko" ? "en" : "ko"));
const allProjects = primaryProjects.length > 0 ? primaryProjects : fallbackProjects;
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5);

const careersKo = [
  { slug: "bhsn", company: "BHSN", role: "AI 엔지니어", period: "2023.08 — 현재", current: true, bullets: [
    "계약서 검토 AI 설계 및 특허 등록",
    "LLM 학습 · 서빙 · 평가 파이프라인 구축",
    "워크플로우/에이전트 플랫폼 및 외부 파트너 연동",
  ], color: "var(--color-accent)" },
  { slug: "naver-cloud", company: "NAVER Cloud (CLOVA)", role: "리서치 인턴", period: "2022.12 — 2023.02", current: false, bullets: [
    "클로바노트 제목 생성 모델 개발",
    "SFT와 자동 데이터 큐레이션으로 4가지 preference 동시 개선",
  ], color: "var(--color-terminal-green)" },
  { slug: "rok-army", company: "대한민국 육군", role: "정보보호병", period: "2020.05 — 2021.11", current: false, bullets: [
    "폐쇄망(air-gapped) 환경에서 보안 업무 자동화",
    "사이버작전사령관 표창",
  ], color: "var(--color-terminal-amber)" },
];

const careersEn = [
  { slug: "bhsn", company: "BHSN", role: "AI Engineer", period: "2023.08 — Present", current: true, bullets: [
    "Designed contract review AI system (patented)",
    "Built LLM training, serving & evaluation pipelines",
    "Workflow/agent platform & external partner integrations",
  ], color: "var(--color-accent)" },
  { slug: "naver-cloud", company: "NAVER Cloud (CLOVA)", role: "Research Intern", period: "2022.12 — 2023.02", current: false, bullets: [
    "CLOVA Note title generation model development",
    "SFT with automated data curation improving 4 preference types",
  ], color: "var(--color-terminal-green)" },
  { slug: "rok-army", company: "Republic of Korea Army", role: "InfoSec Specialist", period: "2020.05 — 2021.11", current: false, bullets: [
    "Security automation in air-gapped environments",
    "Commendation from Cyber Operations Command",
  ], color: "var(--color-terminal-amber)" },
];

const careers = locale === "ko" ? careersKo : careersEn;
const heroName = locale === "ko" ? profile.name.ko : profile.name.en;
const heroTagline = locale === "ko" ? profileKo.tagline : profile.tagline;

const heroHighlightsKo = [
  "GPU 인프라 · 모델 서빙 최적화 · 오픈소스 기여",
  "자체 모델 학습 & 평가 파이프라인",
  "워크플로우 · 에이전트 · 제품 통합",
  "변호사 등 비개발자를 제품 개발 프로세스에 직접 참여시키는 협업 & 외부 파트너 소통",
];

const heroHighlightsEn = [
  "GPU infrastructure, model serving optimization & open-source contributions",
  "In-house model training & evaluation pipelines",
  "Workflow, agent & product integration",
  "Bringing non-engineers (lawyers) into the product development process & cross-company partner collaboration",
];

const heroHighlights = locale === "ko" ? heroHighlightsKo : heroHighlightsEn;
const careerHeading = locale === "ko" ? "경력" : "Career";
const viewAllCareer = locale === "ko" ? "전체 보기" : "View all";

function careerHref(slug: string) {
  return locale === "ko" ? `${base}/career/${slug}` : `${base}/en/career/${slug}`;
}

function projectHref(id: string) {
  return locale === "ko" ? `${base}/projects/${id}` : `${base}/en/projects/${id.replace(/-en$/, "")}`;
}
---

<Layout title={t(locale, "index.title")} locale={locale}>
  <Hero
    name={heroName}
    tagline={heroTagline}
    description={t(locale, "index.heroDescription")}
    highlights={heroHighlights}
    locale={locale}
  />

  <!-- Career History (compact, linked) -->
  <section class="mx-auto max-w-5xl px-6 pb-16">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <span class="font-mono text-sm text-[var(--color-accent)]" aria-hidden="true">##</span>
        <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">{careerHeading}</h2>
      </div>
      <a href={localePath(locale, "/career")} class="text-sm font-mono text-[var(--color-accent-light)] hover:text-[var(--color-accent)] hover:underline transition-colors">
        {viewAllCareer} &rarr;
      </a>
    </div>

    <div class="space-y-3">
      {careers.map((c) => (
        <a
          href={careerHref(c.slug)}
          class="card-glow group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 md:p-5 transition-all duration-300 hover:border-[var(--color-accent-dark)] hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5"
        >
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap">
                <span class:list={["h-2 w-2 rounded-full shrink-0", c.current ? "animate-pulse" : "opacity-40"]} style={`background: ${c.color}`} aria-hidden="true"></span>
                <span class="text-base font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-light)] transition-colors" style="font-family: var(--font-display);">
                  {c.company}
                </span>
                <span class="text-sm text-[var(--color-text-muted)] font-mono">{c.role}</span>
              </div>
              <ul class="mt-1.5 ml-5 space-y-0.5">
                {c.bullets.map((b: string) => (
                  <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-[var(--color-text-muted)] shrink-0" aria-hidden="true"></span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="hidden md:flex items-center gap-3 shrink-0">
              <span class="font-mono text-xs" style={`color: ${c.color}`}>{c.period}</span>
              <span class="text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity">&rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Projects (compact, linked) -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <span class="font-mono text-sm text-[var(--color-accent)]" aria-hidden="true">##</span>
        <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">{t(locale, "index.featuredProjects")}</h2>
      </div>
      <a href={localePath(locale, "/projects")} class="text-sm font-mono text-[var(--color-accent-light)] hover:text-[var(--color-accent)] hover:underline transition-colors">
        {t(locale, "index.viewAll")} &rarr;
      </a>
    </div>

    <div class="space-y-3">
      {featuredProjects.map((project) => (
        <a
          href={projectHref(project.id)}
          class="card-glow group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 md:p-5 transition-all duration-300 hover:border-[var(--color-accent-dark)] hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5"
        >
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-mono text-xs text-[var(--color-accent-dark)]" aria-hidden="true">&#9656;</span>
                <span class="text-base font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-light)] transition-colors" style="font-family: var(--font-display);">
                  {project.data.title}
                </span>
              </div>
              <ul class="mt-1.5 ml-5 space-y-0.5">
                {project.data.description.split(/[.。]\s*/).filter((s: string) => s.trim()).slice(0, 3).map((s: string) => (
                  <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-[var(--color-text-muted)] shrink-0" aria-hidden="true"></span>
                    <span>{s.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
            <span class="text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity shrink-0">&rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
