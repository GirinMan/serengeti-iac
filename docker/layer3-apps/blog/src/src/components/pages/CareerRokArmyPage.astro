        to: "보안 관제와 로그 분석 실무가 token usage tracking, Sentry 기반 운영 모니터링 같은 observability 설계의 기초",
      },
      {
        from: "절차 기반 운영",
        to: "군의 엄격한 절차가 프로덕션 AI 시스템의 rollout 프로세스, QA/prod 분리, workspace-aware 배포 규칙 설계로 이어짐",
      },
    ],
    recognitions: [
      { metric: "4건", label: "공식 인정", detail: "횃불상, 공모전 최우수, 조기진급, 사이버작전사령관 표창" },
      { metric: "18개월", label: "복무 기간", detail: "2020.05 — 2021.11" },
      { metric: "4.5개월", label: "분대장 역임", detail: "병사 중 조직 운영 책임" },
      { metric: "폐쇄망", label: "stdlib only", detail: "외부 패키지 없이 표준 라이브러리만으로 구현" },
    ],
    skills: [
      "보안 관제 (UTM, 로그 분석)", "사이버 방호", "인프라 관리",
