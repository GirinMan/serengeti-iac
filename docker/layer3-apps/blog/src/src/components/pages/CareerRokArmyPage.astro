---
import Layout from "../Layout.astro";
import PageCTA from "../PageCTA.astro";
import { t, localePath } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

/* ------------------------------------------------------------------ */
/*  Locale-specific data                                              */
/* ------------------------------------------------------------------ */

const data = {
  ko: {
    layoutTitle: "육군 — 경력 상세",
    layoutDescription: "대한민국 육군 정보보호병 복무 상세.",
    headerTitle: "정보보호병 (전문특기병)",
    headerOrg: "대한민국 육군",
    headerLocation: "3군단 103정보통신단 사이버방호실 통합관제팀 | 강원도 인제군",
    description: "약 18개월간 대한민국 육군 전문특기병 정보보호병으로 복무했습니다. 외부와 완전히 분리된 폐쇄망(air-gapped) 환경에서 보안 관제, 기반체계 운영, 자동화 프로그램 개발을 수행했습니다. 제한된 환경에서의 문제 해결 경험은 이후 on-premise 성격의 환경을 이해하는 기반이 되었습니다.",
    disclaimer: "구체적인 네트워크 구조, 자동화 프로그램의 상세 구현, 운영 절차는 군사기밀상 공개할 수 없습니다.",
    serviceTimelineHeading: "복무 이력",
    responsibilities: [
      { icon: "🛡️", text: "육군 전문특기병 정보보호병(175104)으로 선발되어 복무" },
      { icon: "📡", text: "사이버방호실 통합관제팀에서 군단급 보안 관제 및 기반체계 운영 지원" },
      { icon: "🖥️", text: "내부망 서버 관리, UTM 관제, 보안 로그 분석" },
      { icon: "⚙️", text: "반복 업무를 줄이기 위한 자동화 프로그램 개발 — 외부 패키지 없이 폐쇄망 제약 하에서 구현" },
      { icon: "🔍", text: "보안 관제와 기반체계 운영에서 반복되는 수작업 프로세스를 분석하고 자동화 가능 영역 식별" },
    ],
    serviceTimeline: [
      { date: "2020-05-18", event: "입대, 전문특기병 정보보호병(175104) 선발" },
      { date: "2020-07-16", event: "정보보호 5기 성적우수 횃불상 수상" },
