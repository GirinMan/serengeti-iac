    ],
  },
  en: {
    layoutTitle: "ROK Army — Career Detail",
    layoutDescription: "Republic of Korea Army InfoSec Specialist service details.",
    headerTitle: "InfoSec Specialist (Specialist Conscript)",
    headerOrg: "Republic of Korea Army",
    headerLocation: "III Corps, 103rd Signal Brigade, Cyber Defense Division | Inje, Gangwon-do",
    description: "Served approximately 18 months as an InfoSec Specialist in the ROK Army. Performed security monitoring, infrastructure operations, and automation development in a completely air-gapped environment. The experience of problem-solving under constrained conditions became a foundation for understanding on-premise environments later in my career.",
    disclaimer: "Specific network architecture, detailed automation implementations, and operational procedures cannot be disclosed due to military confidentiality.",
    serviceTimelineHeading: "Service Timeline",
    responsibilities: [
      { icon: "🛡️", text: "Selected and served as InfoSec Specialist (MOS 175104) in the ROK Army" },
      { icon: "📡", text: "Supported corps-level security monitoring and infrastructure operations in the Cyber Defense Division" },
      { icon: "🖥️", text: "Managed internal network servers, UTM monitoring, and security log analysis" },
      { icon: "⚙️", text: "Developed automation programs to reduce repetitive tasks — built within air-gapped constraints without external packages" },
      { icon: "🔍", text: "Analyzed repetitive manual processes in security monitoring and infrastructure operations, identifying areas for automation" },
    ],
    serviceTimeline: [
      { date: "2020-05-18", event: "Enlisted, selected as InfoSec Specialist (MOS 175104)" },
      { date: "2020-07-16", event: "InfoSec Class 5 Top Performer Award (Torch Award)" },
      { date: "2020-09-29", event: "Army Core Values Contest (Poster category) Grand Prize" },
      { date: "2020-12-01", event: "Early promotion to Corporal" },
      { date: "2021-04-16", event: "Appointed as Squad Leader" },
      { date: "2021-08-31", event: "Squad Leader assignment ended" },
      { date: "2021-11-21", event: "Discharged" },
      { date: "2025-11-19", event: "Cyber Operations Command Commendation (Reserve Forces contribution)" },
    ],
    connections: [
      {
        from: "Air-gapped Operations",
        to: "Background for naturally understanding environment constraints when managing AICA H100 infrastructure and on-prem deployments at BHSN",
      },
      {
        from: "Automation Mindset",
        to: "Habit of identifying and automating repetitive tasks carried over to playbook release workflows, daily scrum automation, and CI/CD pipeline design",
      },
      {
        from: "Security Awareness",
        to: "Practical security monitoring and log analysis experience became the foundation for observability design like token usage tracking and Sentry-based operational monitoring",
      },
      {
        from: "Procedure-Based Operations",
        to: "Military's strict procedures translated to production AI system rollout processes, QA/prod separation, and workspace-aware deployment rules",
      },
    ],
    recognitions: [
      { metric: "4", label: "Official Recognitions", detail: "Torch Award, Contest Grand Prize, Early Promotion, Commander Commendation" },
      { metric: "18mo", label: "Service Period", detail: "2020.05 — 2021.11" },
      { metric: "4.5mo", label: "Squad Leader", detail: "Organizational leadership role" },
      { metric: "Air-gapped", label: "stdlib only", detail: "Built with standard library only — no external packages" },
    ],
    skills: [
      "Security Monitoring (UTM, Log Analysis)", "Cyber Defense", "Infrastructure Management",
      "Air-gapped / On-premise", "Automation (stdlib only)", "Process Analysis & Automation",
      "Team Leadership (Squad Leader)",
    ],
  },
} as const;

const d = data[locale];
---

<Layout title={d.layoutTitle} description={d.layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    {/* Back link */}
    <a href={localePath(locale, "/career")} class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent-light)] transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t(locale, "career.backToCareer")}
    </a>

    {/* Header */}
    <div>
      <p class="text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] font-mono">
        2020.05 — 2021.11
      </p>
      <h1 class="mt-2 text-3xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">
        {d.headerTitle}
      </h1>
      <p class="mt-1 text-lg text-[var(--color-accent-light)]">{d.headerOrg}</p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{d.headerLocation}</p>
    </div>

    <p class="mt-6 text-base leading-relaxed text-[var(--color-text-secondary)] max-w-3xl">
      {d.description}
    </p>
    <p class="mt-2 text-xs text-[var(--color-text-muted)] italic">
      {d.disclaimer}
    </p>

    {/* Recognition Banner */}
    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      {d.recognitions.map((r) => (
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 text-center">
          <p class="text-xl font-bold text-[var(--color-accent-light)]" style="font-family: var(--font-display);">{r.metric}</p>
          <p class="mt-1 text-xs font-medium text-[var(--color-text-primary)]">{r.label}</p>
          <p class="mt-0.5 text-xs text-[var(--color-text-muted)]">{r.detail}</p>
        </div>
      ))}
    </div>

    {/* Responsibilities */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">💼</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.responsibilities")}</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {d.responsibilities.map((r) => (
          <div class="responsibility-card">
            <div class="resp-icon" aria-hidden="true">{r.icon}</div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{r.text}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Service Timeline */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">📅</span>
        <h2 class="text-lg font-semibold">{d.serviceTimelineHeading}</h2>
      </div>
      <div class="space-y-0">
        {d.serviceTimeline.map((tl, i) => (
          <div class="relative pl-8 pb-5 last:pb-0">
            {i < d.serviceTimeline.length - 1 && (
              <div class="absolute left-[5px] top-2 bottom-0 w-px bg-[var(--color-border)]"></div>
            )}
            <div class:list={[
              "absolute left-0 top-2 h-[11px] w-[11px] rounded-full border-2",
              i === d.serviceTimeline.length - 1
                ? "border-[var(--color-accent)] bg-[var(--color-accent)]/20"
                : "border-[var(--color-border)] bg-[var(--color-bg-secondary)]",
            ]}></div>
            <p class="text-xs font-mono text-[var(--color-text-muted)]">{tl.date}</p>
            <p class="mt-0.5 text-sm text-[var(--color-text-secondary)]">{tl.event}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Connection to Later Career */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">🔗</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.connection")}</h2>
      </div>
      <div class="space-y-3">
        {d.connections.map((c) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <p class="text-sm font-medium text-[var(--color-accent-light)]">{c.from}</p>
            <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{c.to}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Skills */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">⚙️</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.skills")}</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {d.skills.map((s) => (
          <span class="tag-pill rounded-full px-3 py-1 text-xs font-mono">{s}</span>
        ))}
      </div>
    </div>

    <PageCTA locale={locale} links={[
      { label: t(locale, "cta.allProjects"), href: "/projects", primary: true },
      { label: t(locale, "cta.viewSkills"), href: "/skills" },
    ]} />
  </section>
</Layout>
