      { date: "2021-04-16", event: "분대장 임명" },
      { date: "2021-08-31", event: "분대장 임무 종료" },
      { date: "2021-11-21", event: "전역" },
      { date: "2025-11-19", event: "사이버작전사령관 표창 (예비전력 기여)" },
    ],
    connections: [
      {
        from: "폐쇄망 운영",
        to: "BHSN에서 AICA H100 인프라 운영, on-prem 배포 대응 시 환경 제약을 자연스럽게 이해하는 배경",
      },
      {
        from: "자동화 지향",
        to: "반복 업무 식별·자동화 습관이 playbook release workflow, daily scrum 자동화, CI/CD 파이프라인 설계로 연결",
      },
      {
