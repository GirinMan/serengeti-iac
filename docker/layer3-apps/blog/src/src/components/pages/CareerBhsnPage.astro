        {d.responsibilities.map((r) => (
          <div class="responsibility-card">
            <div class="resp-icon" aria-hidden="true">{r.icon}</div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{r.text}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Key Projects */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">🚀</span>
        <h2 class="text-xl font-semibold">{t(locale, "career.keyProjects")}</h2>
      </div>
      <div class="space-y-4">
        {d.keyProjects.map((p) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5">
            <h3 class="text-base font-semibold text-[var(--color-text-primary)]">{p.title}</h3>
            <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{p.desc}</p>
            <ul class="mt-3 space-y-1">
              {p.metrics.map((m) => (
                <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
                  <span class="text-[var(--color-accent)] shrink-0" aria-hidden="true">+</span>
                  <span>{m}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {/* Achievements */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">🏆</span>
        <h2 class="text-xl font-semibold">{t(locale, "career.achievements")}</h2>
      </div>
      <ul class="space-y-2">
        {d.achievements.map((a) => (
          <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-secondary)]">
            <span class="text-[var(--color-accent)] mt-0.5 shrink-0" aria-hidden="true">+</span>
            {a.url ? (
              <a href={a.url} target="_blank" rel="noopener" class="hover:text-[var(--color-accent-light)] hover:underline transition-colors">{a.text} &nearr;</a>
            ) : (
              <span>{a.text}</span>
            )}
          </li>
        ))}
      </ul>
    </div>

    {/* Gantt Timeline */}
    <GanttTimeline locale={locale} />

    {/* Skills */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">⚙️</span>
        <h2 class="text-xl font-semibold">{t(locale, "career.skills")}</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {skills.map((s) => (
          <span class="tag-pill rounded-full px-3 py-1 text-xs font-mono">{s}</span>
        ))}
      </div>
    </div>

    <PageCTA locale={locale} links={[
      { label: t(locale, "cta.allProjects"), href: "/projects", primary: true },
      { label: t(locale, "cta.viewSkills"), href: "/skills" },
    ]} />
  </section>
</Layout>
