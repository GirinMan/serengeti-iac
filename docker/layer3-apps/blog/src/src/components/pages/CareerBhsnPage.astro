      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t(locale, "career.backToCareer")}
    </a>

    {/* Header */}
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <p class="text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] font-mono">
          {d.period}
          <span class="ml-2 inline-flex items-center rounded-full bg-[var(--color-accent)]/15 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-accent-light)]">CURRENT</span>
        </p>
        <h1 class="mt-2 text-3xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">
          AI Engineer / NLP Engineer
        </h1>
        <p class="mt-1 text-lg text-[var(--color-accent-light)]">BHSN</p>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">{d.location}</p>
        <div class="mt-3 flex flex-wrap gap-3">
          <a href="https://www.allibee.ai" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
            allibee.ai &nearr;
          </a>
          <a href="https://drive.google.com/file/d/1rRJ2EO1J2Hhonxr8bNvISnVFqYz5iL5s/view" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
            {d.linkLabels.langcon} &nearr;
          </a>
          <a href="https://www.allibee.ai/blog/reasoning-over-inference" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
            {d.linkLabels.blogReasoning} &nearr;
          </a>
          <a href="https://www.allibee.ai/blog/rope-nope-architecture" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
            {d.linkLabels.blogRope} &nearr;
          </a>
          <a href="https://www.hankookilbo.com/news/article/A2024021223120004257" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
            {d.linkLabels.hankook} &nearr;
          </a>
