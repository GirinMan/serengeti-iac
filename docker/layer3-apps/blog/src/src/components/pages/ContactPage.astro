---
import Layout from "../Layout.astro";
import contact from "../../data/contact.json";
import { t } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

const layoutDescription = locale === "ko" ? "연락처." : "Get in touch.";
const emailAriaLabel = locale === "ko"
  ? `${contact.email}로 이메일 보내기`
  : `Send email to ${contact.email}`;
const githubAriaLabel = locale === "ko" ? "GitHub 프로필 방문" : "Visit GitHub profile";
const linkedinAriaLabel = locale === "ko" ? "LinkedIn 프로필 방문" : "Visit LinkedIn profile";
const huggingfaceAriaLabel = locale === "ko" ? "Hugging Face 프로필 방문" : "Visit Hugging Face profile";
const emailLabel = locale === "ko" ? "이메일" : "Email";
---

<Layout title={t(locale, "contact.title")} description={layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16" >
    <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">{t(locale, "contact.heading")}</h1>
    <p class="mt-3 text-base text-[var(--color-text-secondary)] max-w-2xl">
      {t(locale, "contact.desc")}
    </p>

    <div class="mt-8 grid gap-6 md:grid-cols-2 max-w-2xl">
      <!-- Email -->
      <a
        href={`mailto:${contact.email}`}
        class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 transition-all duration-200 hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/5"
        aria-label={emailAriaLabel}
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent-light)] transition-colors group-hover:bg-[var(--color-accent)]/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-[var(--color-text-primary)]">{emailLabel}</p>
          <p class="text-xs text-[var(--color-text-muted)]">{contact.email}</p>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href={contact.github}
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 transition-all duration-200 hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/5"
        aria-label={githubAriaLabel}
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent-light)] transition-colors group-hover:bg-[var(--color-accent)]/20">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-[var(--color-text-primary)]">GitHub</p>
          <p class="text-xs text-[var(--color-text-muted)]">GirinMan</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 transition-all duration-200 hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/5"
        aria-label={linkedinAriaLabel}
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent-light)] transition-colors group-hover:bg-[var(--color-accent)]/20">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-[var(--color-text-primary)]">LinkedIn</p>
          <p class="text-xs text-[var(--color-text-muted)]">girinman</p>
        </div>
      </a>

      <!-- Hugging Face -->
      <a
        href={contact.huggingface}
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 transition-all duration-200 hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-bg-hover)] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/5"
        aria-label={huggingfaceAriaLabel}
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent-light)] transition-colors group-hover:bg-[var(--color-accent)]/20">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1.5 7.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm3 0a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM7.5 14c0-1.1.4-2.1 1-2.9.2-.2.5-.2.7 0 .7.8 2 2.4 2.8 2.4s2.1-1.6 2.8-2.4c.2-.2.5-.2.7 0 .6.8 1 1.8 1 2.9 0 2.5-2 4.5-4.5 4.5S7.5 16.5 7.5 14z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-[var(--color-text-primary)]">Hugging Face</p>
          <p class="text-xs text-[var(--color-text-muted)]">GirinMan</p>
        </div>
      </a>
    </div>

    <!-- Currently open to -->
    <div class="mt-12 max-w-2xl rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6">
      <h2 class="text-base font-semibold text-[var(--color-text-primary)]">{t(locale, "contact.openTo")}</h2>
      <ul class="mt-3 space-y-2 text-sm text-[var(--color-text-secondary)]">
        <li class="flex items-start gap-2">
          <span class="mt-1.5 block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
          {t(locale, "contact.openTo1")}
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1.5 block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
          {t(locale, "contact.openTo2")}
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1.5 block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
          {t(locale, "contact.openTo3")}
        </li>
      </ul>
    </div>
  </section>
</Layout>
