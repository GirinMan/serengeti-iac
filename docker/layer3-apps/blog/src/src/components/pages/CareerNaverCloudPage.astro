---
import Layout from "../Layout.astro";
import PageCTA from "../PageCTA.astro";
import { t, localePath } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

/* ------------------------------------------------------------------ */
/*  Locale-specific data                                              */
/* ------------------------------------------------------------------ */

const data = {
  ko: {
    layoutTitle: "NAVER Cloud — 경력 상세",
    layoutDescription: "NAVER Cloud AI Research Engineer 인턴십 상세.",
    headerTitle: "AI Research Engineer (인턴)",
    headerLocation: "경기도 성남시 1784 | Document Intelligence 팀",
    blogLabel: "CLOVA 공식 블로그",
    summaryBullets: [
      "클로바노트 제목 생성 모델 개발 — Document Intelligence 팀, 약 3개월",
      "DPO 등장 이전 시기, SFT + 자동 데이터 큐레이션만으로 4가지 preference 동시 개선",
      "개조식 어미·어절 수·ROUGE precision·semantic similarity 필터링 파이프라인",
      "실제 배포된 NAVER 클로바노트 'AI 요약 소제목' 기능에 기여",
    ],
    contextualNote: "한양대 컴퓨터소프트웨어학부 4학년 재학 중 수행. Google ML Bootcamp 수료, CLOVA AI RUSH 1위 수상 경험이 선발 배경.",
    productSignalHeading: "제품 연결 시그널",
    productSignalBody: `인턴십 종료 3개월 후인 2023-05-12, 네이버 클로바 팀은 <a href="https://blog.naver.com/clova_ai/223100523675" target="_blank" rel="noopener" class="text-[var(--color-accent-light)] hover:underline">공식 블로그</a>에서 클로바노트 <span class="text-[var(--color-text-primary)] font-medium">'AI 요약 소제목 지원'</span>을 공개했습니다. 인턴십 과제의 제품 방향이 외부 릴리스까지 이어졌다는 시그널입니다.`,
    clovaCaption: "CLOVA Note — AI 요약 소제목 기능이 적용된 실제 제품 화면. 음성 기록에서 키워드 추출, 소제목 단위 요약을 제공합니다.",
    techDeepDiveHeading: "기술 심화",
    responsibilities: [
      { icon: "🧠", text: "HyperCLOVA/LaRva 계열 백본을 LoRA(PEFT) 튜닝으로 노트 제목 생성 모델 학습" },
      { icon: "🏷️", text: "Weak labeling 품질 분석 및 positive filtering 규칙 설계" },
      { icon: "🔬", text: "개조식 어미, 어절 개수, ROUGE-1 precision, semantic similarity 기준의 multi-criteria 데이터 필터링 파이프라인 구축" },
      { icon: "📐", text: "RoBERTa-HyperUNICON 기반 LaRva sentence encoder 활용 semantic similarity 계산" },
      { icon: "📊", text: "Streamlit 기반 annotation/분석 도구 개발 — weak label 품질 분포와 필터 결과 시각화" },
      { icon: "🌐", text: "Demo API 구축 — 뉴스 기사, 강의계획서, 영어/일본어 등 OOD 입력 범용성 검증" },
      { icon: "🔄", text: "Positive data만 남겨 재학습하는 SFT iteration 구조 설계 및 반복 실험" },
    ],
    achievements: [
      { metric: "95.98%", label: "Positive data coverage", detail: "83.71%에서 향상" },
      { metric: "-32%", label: "어절 개수 오류율", detail: "15.5% → 10.5%" },
      { metric: "-48%", label: "개조식 오류율", detail: "6.75% → 3.50%" },
      { metric: "-33%", label: "ROUGE-precision 오류율", detail: "23.0% → 15.5%" },
    ],
    techDetails: [
      {
        area: "모델 아키텍처 & 학습",
        bullets: [
          "HyperCLOVA/LaRva 계열 백본 + LoRA(PEFT) 어댑터 — 요약문→제목 생성 SFT",
          "DPO 등장 이전 (2022년 말) — SFT + 자동 데이터 큐레이션만으로 preference 개선",
          "Positive data만 남겨 재학습하는 SFT iteration 구조 설계",
        ],
      },
      {
        area: "Multi-Criteria 필터링 파이프라인",
        bullets: [
          "개조식 어미 검사",
          "어절 개수 2~6개 범위 필터",
          "ROUGE-1 precision >= 0.75",
          "RoBERTa-HyperUNICON 기반 semantic similarity >= 0.9",
        ],
      },
      {
        area: "데이터 규모 & 반복 실험",
        bullets: [
          "Train positive data 1,904건→2,455건 (+29%)",
          "전 항목 오류율 개선 — 개조식 -48%, 어절 수 -32%, ROUGE -33%, semantic -12%",
          "후속 실험 — coverage 95.98%, valid 개조식 오류 12건→1건 (-92%)",
        ],
      },
    ],
    connections: [
      {
        from: "DPO 없이 SFT + 자동 큐레이션으로 preference 개선",
        to: "DPO가 없던 시기에 데이터 품질만으로 모델 선호도를 조정한 경험 → BHSN에서 법률 도메인 SFT/DPO 데이터 파이프라인 설계의 기반",
      },
      {
        from: "평가 지표 설계",
        to: "BHSN에서 20+ 법률 AI 평가 메트릭과 LLM-as-a-Judge 프레임워크 설계",
      },
      {
        from: "LoRA 튜닝 실무",
        to: "BHSN에서 Qwen2.5-14B 기반 5종 task-specific 어댑터 학습, predibase/lorax OSS 기여",
      },
      {
        from: "Applied NLP delivery",
        to: "모델 학습 → 데이터 필터링 → 평가 도구 → demo API 연결 — 이후 법률 AI end-to-end 개발의 원형",
      },
    ],
  },
  en: {
    layoutTitle: "NAVER Cloud — Career Detail",
    layoutDescription: "NAVER Cloud AI Research Engineer internship details.",
    headerTitle: "AI Research Engineer (Intern)",
    headerLocation: "Seongnam, Gyeonggi-do, 1784 | Document Intelligence Team",
    blogLabel: "CLOVA Official Blog",
    summaryBullets: [
      "CLOVA Note title generation model — Document Intelligence team, ~3 months",
      "Pre-DPO era: improved 4 preferences simultaneously using only SFT + automatic data curation",
      "Bullet-point style · word count · ROUGE precision · semantic similarity filtering pipeline",
      "Contributed to shipped NAVER CLOVA Note 'AI Summary Subtitles' feature",
    ],
    contextualNote: "Conducted during senior year at Hanyang University, Department of Computer Software. Selected based on Google ML Bootcamp completion and CLOVA AI RUSH 1st place.",
    productSignalHeading: "Product Connection Signal",
    productSignalBody: `Three months after the internship ended, on 2023-05-12, the NAVER CLOVA team announced <span class="text-[var(--color-text-primary)] font-medium">'AI Summary Subtitles'</span> for CLOVA Note on their <a href="https://blog.naver.com/clova_ai/223100523675" target="_blank" rel="noopener" class="text-[var(--color-accent-light)] hover:underline">official blog</a>. This signals that the internship project's direction carried through to an external product release.`,
    clovaCaption: "CLOVA Note — AI Summary Subtitles feature in production. Provides keyword extraction and subtitle-level summarization from voice recordings.",
    techDeepDiveHeading: "Technical Deep Dive",
    responsibilities: [
      { icon: "🧠", text: "Trained CLOVA Note title generation model using HyperCLOVA/LaRva backbone with LoRA (PEFT) tuning" },
      { icon: "🏷️", text: "Analyzed weak labeling quality and designed positive filtering rules" },
      { icon: "🔬", text: "Built multi-criteria data filtering pipeline based on bullet-point endings, word count, ROUGE-1 precision, and semantic similarity" },
      { icon: "📐", text: "Computed semantic similarity using RoBERTa-HyperUNICON-based LaRva sentence encoder" },
      { icon: "📊", text: "Developed Streamlit-based annotation/analysis tools — visualized weak label quality distribution and filter results" },
      { icon: "🌐", text: "Built demo API — verified generalizability on OOD inputs (news articles, syllabi, English/Japanese)" },
      { icon: "🔄", text: "Designed and iterated SFT loop retaining only positive data for retraining" },
    ],
    achievements: [
      { metric: "95.98%", label: "Positive Data Coverage", detail: "Up from 83.71%" },
      { metric: "-32%", label: "Word Count Error Rate", detail: "15.5% → 10.5%" },
      { metric: "-48%", label: "Bullet-point Error Rate", detail: "6.75% → 3.50%" },
      { metric: "-33%", label: "ROUGE-precision Error Rate", detail: "23.0% → 15.5%" },
    ],
    techDetails: [
      {
        area: "Model Architecture & Training",
        bullets: [
          "HyperCLOVA/LaRva backbone + LoRA (PEFT) adapter — summary→title generation SFT",
          "Pre-DPO era (late 2022) — improved preferences purely through SFT + automatic data curation",
          "Designed SFT iteration loop retaining only positive data for retraining",
        ],
      },
      {
        area: "Multi-Criteria Filtering Pipeline",
        bullets: [
          "Bullet-point ending style check",
          "Word count within 2–6 range filter",
          "ROUGE-1 precision >= 0.75",
          "Semantic similarity >= 0.9 via RoBERTa-HyperUNICON-based LaRva sentence encoder",
        ],
      },
      {
        area: "Data Scale & Iterative Experiments",
        bullets: [
          "Train positive data 1,904→2,455 (+29%)",
          "Error rates improved across all criteria — bullet-point -48%, word count -32%, ROUGE -33%, semantic -12%",
          "Follow-up experiment — coverage 95.98%, valid bullet-point errors 12→1 (-92%)",
        ],
      },
    ],
    connections: [
      {
        from: "Data Quality-Centric Approach",
        to: "At BHSN, designed weak supervision and automatic filtering for legal domain SFT data construction",
      },
      {
        from: "Evaluation Metric Design",
        to: "At BHSN, designed 20+ legal AI evaluation metrics and LLM-as-a-Judge framework",
      },
      {
        from: "LoRA Tuning Practice",
        to: "At BHSN, trained 5 task-specific adapters on Qwen2.5-14B backbone, contributed to predibase/lorax OSS",
      },
      {
        from: "Applied NLP Delivery",
        to: "Model training → data filtering → evaluation tooling → demo API — the prototype for end-to-end legal AI development",
      },
    ],
  },
} as const;

const d = data[locale];

const skills = [
  "LoRA / PEFT", "HyperCLOVA / LaRva", "Weak Labeling",
  "Positive Filtering", "ROUGE / Semantic Similarity",
  "Streamlit", "Demo API Prototyping", "Document Intelligence",
];
---

<Layout title={d.layoutTitle} description={d.layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    {/* Back link */}
    <a href={localePath(locale, "/career")} class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent-light)] transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t(locale, "career.backToCareer")}
    </a>

    {/* Header */}
    <div>
      <p class="text-xs font-medium tracking-wider uppercase text-[var(--color-text-muted)] font-mono">
        2022.12 — 2023.02
      </p>
      <h1 class="mt-2 text-3xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">
        {d.headerTitle}
      </h1>
      <p class="mt-1 text-lg text-[var(--color-accent-light)]">NAVER / NAVER Cloud</p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{d.headerLocation}</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a href="https://blog.naver.com/clova_ai/223100523675" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-xs font-mono text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] transition-colors">
          {d.blogLabel} &nearr;
        </a>
      </div>
    </div>

    <ul class="mt-6 space-y-2 max-w-3xl">
      {d.summaryBullets.map((item) => (
        <li class="flex items-start gap-2 text-base text-[var(--color-text-secondary)]">
          <span class="text-[var(--color-accent)] shrink-0 mt-0.5">•</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
    <p class="mt-3 text-sm text-[var(--color-text-muted)]">
      {d.contextualNote}
    </p>

    {/* Key Metrics */}
    <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
      {d.achievements.map((a) => (
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 text-center">
          <p class="text-2xl font-bold text-[var(--color-accent-light)]" style="font-family: var(--font-display);">
            {a.metric}
          </p>
          <p class="mt-1 text-xs font-medium text-[var(--color-text-primary)]">{a.label}</p>
          <p class="mt-0.5 text-xs text-[var(--color-text-muted)]">{a.detail}</p>
        </div>
      ))}
    </div>

    {/* Product Signal */}
    <div class="mt-10">
      <div class="rounded-xl border border-[var(--color-accent)]/20 bg-[var(--color-accent)]/5 p-5">
        <p class="text-sm font-semibold text-[var(--color-accent-light)]">{d.productSignalHeading}</p>
        <p class="mt-2 text-sm text-[var(--color-text-secondary)]" set:html={d.productSignalBody} />
        {/* CLOVA Note Product Screenshot */}
        <div class="mt-4 rounded-lg border border-[var(--color-border)] overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}/images/career/clovanote-ai-summary.png`}
            alt="CLOVA Note AI Summary Subtitles — product screenshot showing keyword extraction and subtitle-level AI summarization from voice recordings"
            class="w-full"
            loading="lazy"
          />
          <div class="px-4 py-2 bg-[var(--color-bg-secondary)] border-t border-[var(--color-border)]">
            <p class="text-xs text-[var(--color-text-muted)]">
              {d.clovaCaption}
            </p>
          </div>
        </div>
      </div>
    </div>

    {/* Technical Deep Dive */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">🔬</span>
        <h2 class="text-lg font-semibold">{d.techDeepDiveHeading}</h2>
      </div>
      <div class="space-y-3">
        {d.techDetails.map((td) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5">
            <h3 class="text-sm font-semibold text-[var(--color-accent-light)] font-mono">{td.area}</h3>
            <ul class="mt-2 space-y-1.5">
              {td.bullets.map((b) => (
                <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">
                  <span class="text-[var(--color-accent)] shrink-0 mt-0.5">•</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {/* Responsibilities */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">💼</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.responsibilities")}</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {d.responsibilities.map((r) => (
          <div class="responsibility-card">
            <div class="resp-icon" aria-hidden="true">{r.icon}</div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{r.text}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Connection to Later Career */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">🔗</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.connection")}</h2>
      </div>
      <div class="space-y-3">
        {d.connections.map((c) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <p class="text-sm font-medium text-[var(--color-accent-light)]">{c.from}</p>
            <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{c.to}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Skills */}
    <div class="mt-12">
      <div class="section-heading">
        <span class="section-icon" aria-hidden="true">⚙️</span>
        <h2 class="text-lg font-semibold">{t(locale, "career.skills")}</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {skills.map((s) => (
          <span class="tag-pill rounded-full px-3 py-1 text-xs font-mono">{s}</span>
        ))}
      </div>
    </div>

    <PageCTA locale={locale} links={[
      { label: t(locale, "cta.allProjects"), href: "/projects", primary: true },
      { label: t(locale, "cta.viewSkills"), href: "/skills" },
    ]} />
  </section>
</Layout>
