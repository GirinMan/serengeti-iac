---
import Layout from "../Layout.astro";
import SkillBadge from "../SkillBadge.astro";
import SkillLayerStack3D from "../SkillLayerStack3D.astro";
import PageCTA from "../PageCTA.astro";
import { getCollection } from "astro:content";
import { t, localePath } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

const allSkills = await getCollection("skills", (s) => s.data.locale === locale);
const skills = allSkills.sort((a, b) => (a.data.layerOrder ?? a.data.order) - (b.data.layerOrder ?? b.data.order));

// Group skills by layer field from content data
const layerGroups: Record<string, typeof skills> = {};
for (const skill of skills) {
  const layer = skill.data.layer ?? "cross-cutting";
  if (!layerGroups[layer]) layerGroups[layer] = [];
  layerGroups[layer].push(skill);
}

const layerDefs = locale === "ko"
  ? [
      { key: "applications", id: 5, label: "애플리케이션", icon: "🔺", layers: ["applications", "applications-agent"] },
      { key: "models", id: 4, label: "모델 & 인텔리전스", icon: "🧠", layers: ["models-foundation", "models-domain", "models-evaluation"] },
      { key: "infrastructure", id: 3, label: "인프라 & 서빙", icon: "⚡", layers: ["infrastructure-serving", "infrastructure"] },
      { key: "chips", id: 2, label: "칩 & 가속기", icon: "🔲", layers: ["chips"] },
      { key: "cross-cutting", id: 0, label: "공통 역량", icon: "🔗", layers: ["cross-cutting", "cross-cutting-collab"] },
    ]
  : [
      { key: "applications", id: 5, label: "Applications", icon: "🔺", layers: ["applications", "applications-agent"] },
      { key: "models", id: 4, label: "Models & Intelligence", icon: "🧠", layers: ["models-foundation", "models-domain", "models-evaluation"] },
      { key: "infrastructure", id: 3, label: "Infrastructure & Serving", icon: "⚡", layers: ["infrastructure-serving", "infrastructure"] },
      { key: "chips", id: 2, label: "Chips & Accelerators", icon: "🔲", layers: ["chips"] },
      { key: "cross-cutting", id: 0, label: "Cross-cutting", icon: "🔗", layers: ["cross-cutting", "cross-cutting-collab"] },
    ];

const subLayerLabels: Record<string, string> = locale === "ko"
  ? {
      "applications": "LLM 앱 & 서비스",
      "applications-agent": "에이전트 & 워크플로우",
      "models-foundation": "파운데이션 모델",
      "models-domain": "도메인 특화",
      "models-evaluation": "평가 & 데이터",
      "infrastructure-serving": "모델 서빙",
      "infrastructure": "백엔드 & 클라우드",
      "chips": "GPU · NPU · 가속기",
      "cross-cutting": "언어 & 도구",
      "cross-cutting-collab": "협업 & 리더십",
    }
  : {
      "applications": "LLM Apps & Services",
      "applications-agent": "Agents & Workflows",
      "models-foundation": "Foundation Models",
      "models-domain": "Domain Specialization",
      "models-evaluation": "Evaluation & Data",
      "infrastructure-serving": "Model Serving",
      "infrastructure": "Backend & Cloud",
      "chips": "GPU · NPU · Accelerators",
      "cross-cutting": "Languages & Tools",
      "cross-cutting-collab": "Collaboration & Leadership",
    };

const resolvedLayers = layerDefs.map((def) => ({
  ...def,
  sublayers: def.layers
    .filter((l) => layerGroups[l]?.length)
    .map((l) => ({ key: l, label: subLayerLabels[l] || l, skills: layerGroups[l] })),
})).filter((l) => l.sublayers.length > 0);

const layoutDescription = locale === "ko" ? "기술 스택 및 주요 역량." : "Technical skills and expertise areas.";

// Map skill layers to project tags for cross-linking
const layerProjectLinks: Record<string, { tags: string[]; label: string }> = locale === "ko"
  ? {
      applications: { tags: ["LangGraph", "Agent", "Workflow"], label: "관련 프로젝트 보기" },
      models: { tags: ["SFT", "DPO", "Training", "Evaluation"], label: "관련 프로젝트 보기" },
      infrastructure: { tags: ["vLLM", "Serving", "Infrastructure"], label: "관련 프로젝트 보기" },
    }
  : {
      applications: { tags: ["LangGraph", "Agent", "Workflow"], label: "View related projects" },
      models: { tags: ["SFT", "DPO", "Training", "Evaluation"], label: "View related projects" },
      infrastructure: { tags: ["vLLM", "Serving", "Infrastructure"], label: "View related projects" },
    };
---

<Layout title={t(locale, "skills.title")} description={layoutDescription} locale={locale}>
  <section class="skills-page">
    <!-- Page Header -->
    <div class="skills-header">
      <div class="flex items-center gap-3 mb-2">
        <span class="font-mono text-sm text-[var(--color-accent)]" aria-hidden="true">##</span>
        <h1 class="text-3xl font-bold" style="font-family: var(--font-display);">{t(locale, "skills.heading")}</h1>
      </div>
      <p class="mt-3 text-base text-[var(--color-text-secondary)] max-w-2xl ml-7">
        {t(locale, "skills.desc")}
      </p>
    </div>

    <!-- Desktop: 2-column / Mobile: stacked -->
    <div class="skills-split">
      <!-- Left: 3D Layer Stack (sticky on desktop) -->
      <div class="skills-left">
        <SkillLayerStack3D locale={locale} />
      </div>

      <!-- Right: Skill Cards -->
      <div class="skills-right">
        {resolvedLayers.map((layer) => (
          <div class="skills-layer-group" id={`layer-${layer.key}`}>
            <div class="flex items-center gap-3 mb-5 pb-3 border-b-2 border-[var(--color-accent)]/20">
              {layer.id > 0 && <span class="font-mono text-xs text-[var(--color-accent-dark)] opacity-70" aria-hidden="true">L{layer.id}</span>}
              <span class="text-lg" aria-hidden="true">{layer.icon}</span>
              <h2 class="text-xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">{layer.label}</h2>
            </div>

            {layer.sublayers.map((sub) => (
              <div class="mt-6 ml-2" id={`layer-${sub.key}`} data-category-section={sub.key}>
                <div class="section-heading">
                  <h3 class="text-lg font-semibold">{sub.label}</h3>
                </div>
                <div class="grid gap-3 grid-cols-1 lg:grid-cols-2" role="list">
                  {sub.skills.map((skill) => (
                    <SkillBadge
                      name={skill.data.name}
                      description={skill.data.description}
                      variant={skill.data.description ? "card" : "badge"}
                    />
                  ))}
                </div>
              </div>
            ))}

            {layerProjectLinks[layer.key] && (
              <a
                href={localePath(locale, "/projects")}
                class="mt-5 ml-2 inline-flex items-center gap-1.5 text-sm font-mono text-[var(--color-text-muted)] hover:text-[var(--color-accent-light)] transition-colors"
              >
                {layerProjectLinks[layer.key].label}
                <span class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
              </a>
            )}
          </div>
        ))}

        <PageCTA locale={locale} links={[
          { label: t(locale, "cta.viewProjects"), href: "/projects", primary: true },
          { label: t(locale, "cta.getInTouch"), href: "/contact" },
        ]} />
      </div>
    </div>
  </section>
</Layout>

<style>
  .skills-page {
    max-width: 100%;
    padding: 2rem 1.5rem;
  }

  .skills-header {
    max-width: 72rem;
    margin: 0 auto 1.5rem;
    padding: 0 0.5rem;
  }

  /* Desktop: side-by-side */
  @media (min-width: 1200px) {
    .skills-split {
      display: grid;
      grid-template-columns: minmax(480px, 50%) 1fr;
      gap: 2rem;
      max-width: 100%;
      margin: 0 auto;
      align-items: start;
    }

    .skills-left {
      position: sticky;
      top: 4.5rem;
      max-height: calc(100vh - 5rem);
      overflow-y: auto;
      scrollbar-width: none;
    }

    .skills-left::-webkit-scrollbar { width: 0; }

    .skills-right {
      padding-top: 0.5rem;
    }

    .skills-layer-group {
      margin-bottom: 2.5rem;
    }

    .skills-page {
      max-width: 100%;
      padding: 2rem 2rem;
    }

    .skills-header {
      max-width: 100%;
      padding: 0 0.5rem;
    }
  }

  /* Tablet & below: stacked */
  @media (max-width: 1199px) {
    .skills-split {
      max-width: 64rem;
      margin: 0 auto;
    }

    .skills-left {
      margin-bottom: 2rem;
    }

    .skills-layer-group {
      margin-top: 2.5rem;
    }
  }
</style>
