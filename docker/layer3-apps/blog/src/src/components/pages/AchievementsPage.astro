---
import Layout from "../Layout.astro";
import AchievementCard from "../AchievementCard.astro";
import OpenSourceLoraxSection from "../OpenSourceLoraxSection.astro";
import { getCollection } from "astro:content";
import { t, localePath } from "../../i18n";
import { getOssPrs } from "../../data/opensource-prs";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

const primaryAchievements = await getCollection("achievements", (a) => a.data.locale === locale);
const fallbackAchievements = await getCollection("achievements", (a) => a.data.locale === (locale === "ko" ? "en" : "ko"));
const allAchievements = primaryAchievements.length > 0 ? primaryAchievements : fallbackAchievements;
const achievements = allAchievements.sort((a, b) => a.data.order - b.data.order);

const noLocaleAchievements = await getCollection("achievements", (a) => !a.data.locale);
const merged = [...achievements, ...noLocaleAchievements].sort((a, b) => a.data.order - b.data.order);

const ossPrs = getOssPrs(locale);

const categoryOrder = ["patent", "competition", "speaking", "opensource", "award", "certification"] as const;

const categoryConfig: Record<string, { icon: string; label: string; color: string; bgAlpha: string }> = {
  patent:        { icon: "🔬", label: t(locale, "achievements.cat.patent"),        color: "var(--color-accent-light)", bgAlpha: "rgba(232, 200, 138, 0.12)" },
  speaking:      { icon: "🎤", label: t(locale, "achievements.cat.speaking"),      color: "var(--color-skill-advanced)", bgAlpha: "rgba(245, 158, 11, 0.12)" },
  competition:   { icon: "🏆", label: t(locale, "achievements.cat.competition"),   color: "var(--color-skill-expert)", bgAlpha: "rgba(239, 68, 68, 0.12)" },
  certification: { icon: "📜", label: t(locale, "achievements.cat.certification"), color: "var(--color-skill-beginner)", bgAlpha: "rgba(110, 231, 183, 0.12)" },
  award:         { icon: "🏅", label: t(locale, "achievements.cat.award"),         color: "var(--color-accent)", bgAlpha: "rgba(212, 160, 106, 0.12)" },
  opensource:    { icon: "🔓", label: t(locale, "achievements.cat.opensource"),     color: "var(--color-terminal-green)", bgAlpha: "rgba(34, 197, 94, 0.12)" },
};

const grouped: Record<string, typeof merged> = {};
for (const item of merged) {
  const cat = item.data.category;
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(item);
}

const sortedGroups = categoryOrder
  .filter((key) => grouped[key]?.length)
  .map((key) => ({
    key,
    config: categoryConfig[key],
    items: grouped[key],
  }));

const counts = categoryOrder.map(k => ({
  key: k,
  count: grouped[k]?.length || 0,
  ...categoryConfig[k],
})).filter(c => c.count > 0);

const byYear: Record<string, typeof merged> = {};
for (const item of merged) {
  const year = item.data.date.substring(0, 4);
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(item);
}
const timelineYears = Object.keys(byYear).sort().reverse();

const highlights = merged.filter(a => a.data.order <= 3);

const heading = t(locale, "achievements.heading");
const desc = t(locale, "achievements.desc");
const allLabel = locale === "ko" ? "전체" : "All";
const categoryViewLabel = locale === "ko" ? "카테고리별" : "By Category";
const timelineViewLabel = locale === "ko" ? "시간순" : "Timeline";
const summaryAriaLabel = locale === "ko" ? "성과 요약" : "Achievement summary";
const layoutDescription = locale === "ko" ? "수상, 특허, 자격증, 발표 등 주요 성과." : "Awards, patents, certifications, and speaking engagements.";
---

<Layout title={t(locale, "achievements.title")} description={layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16" id="achievements-page">
    <!-- Page Header -->
    <div class="flex items-center gap-3 mb-2">
      <span class="font-mono text-sm text-[var(--color-accent)]" aria-hidden="true">##</span>
      <h1 class="text-3xl font-bold" style="font-family: var(--font-display);">{heading}</h1>
    </div>
    <p class="mt-3 text-base text-[var(--color-text-secondary)] max-w-2xl ml-7">{desc}</p>

    <!-- Summary Count Strip -->
    <div class="achv-counts" aria-label={summaryAriaLabel}>
      {counts.map(c => (
        <button
          class="achv-count-item"
          data-achv-filter={c.key}
          style={`--cat-color: ${c.color};`}
        >
          <span class="achv-count-icon" aria-hidden="true">{c.icon}</span>
          <span class="achv-count-num">{c.count}</span>
          <span class="achv-count-label">{c.label}</span>
        </button>
      ))}
    </div>

    <!-- View Toggle + Filter -->
    <div class="achv-controls">
      <div class="achv-view-toggle" role="tablist">
        <button class="achv-view-btn achv-view-btn--active" data-view="category" role="tab" aria-selected="true">
          {categoryViewLabel}
        </button>
        <button class="achv-view-btn" data-view="timeline" role="tab" aria-selected="false">
          {timelineViewLabel}
        </button>
      </div>
      <button class="achv-filter-reset" id="achv-filter-reset" style="display:none;">
        {allLabel}
      </button>
    </div>

    <!-- ============ CATEGORY VIEW ============ -->
    <div class="achv-view" id="achv-category-view">
      {/* Patent + Competition merged row */}
      {(grouped["patent"]?.length || grouped["competition"]?.length) && (
        <div class="achv-group" data-achv-group="patent-competition">
          <div class="grid gap-4 sm:grid-cols-2">
            {grouped["patent"]?.map((item) => (
              <div data-achv-category={item.data.category}>
                <div class="achv-group-heading mb-3">
                  <span class="achv-group-icon-badge" style={`background: ${categoryConfig.patent.bgAlpha}; border-color: ${categoryConfig.patent.color}30;`} aria-hidden="true">{categoryConfig.patent.icon}</span>
                  <h2 class="achv-group-title">{categoryConfig.patent.label}</h2>
                </div>
                <AchievementCard
                  title={item.data.title}
                  category={item.data.category}
                  date={item.data.date}
                  description={item.data.description}
                  url={item.data.url}
                  image={item.data.image}
                  issuer={item.data.issuer}
                />
              </div>
            ))}
            {grouped["competition"]?.map((item) => (
              <div data-achv-category={item.data.category}>
                <div class="achv-group-heading mb-3">
                  <span class="achv-group-icon-badge" style={`background: ${categoryConfig.competition.bgAlpha}; border-color: ${categoryConfig.competition.color}30;`} aria-hidden="true">{categoryConfig.competition.icon}</span>
                  <h2 class="achv-group-title">{categoryConfig.competition.label}</h2>
                </div>
                <AchievementCard
                  title={item.data.title}
                  category={item.data.category}
                  date={item.data.date}
                  description={item.data.description}
                  url={item.data.url}
                  image={item.data.image}
                  issuer={item.data.issuer}
                />
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Speaking group */}
      {sortedGroups.filter(g => g.key === "speaking").map((group) => (
        <div class="achv-group" data-achv-group={group.key}>
          <div class="achv-group-heading">
            <span class="achv-group-icon-badge" style={`background: ${group.config.bgAlpha}; border-color: ${group.config.color}30;`} aria-hidden="true">{group.config.icon}</span>
            <h2 class="achv-group-title">{group.config.label}</h2>
            <span class="achv-group-count">{group.items.length}</span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {group.items.map((item) => (
              <div data-achv-category={item.data.category}>
                <AchievementCard title={item.data.title} category={item.data.category} date={item.data.date} description={item.data.description} url={item.data.url} image={item.data.image} issuer={item.data.issuer} />
              </div>
            ))}
          </div>
        </div>
      ))}

      {/* ===== Open Source Contributions Section (shared component) ===== */}
      {grouped["opensource"]?.length > 0 && (
        <div id="opensource">
          <OpenSourceLoraxSection locale={locale} />
        </div>
      )}

      {/* Award + Certification groups */}
      {sortedGroups.filter(g => g.key === "award" || g.key === "certification").map((group) => (
        <div class="achv-group" data-achv-group={group.key}>
          <div class="achv-group-heading">
            <span class="achv-group-icon-badge" style={`background: ${group.config.bgAlpha}; border-color: ${group.config.color}30;`} aria-hidden="true">{group.config.icon}</span>
            <h2 class="achv-group-title">{group.config.label}</h2>
            <span class="achv-group-count">{group.items.length}</span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {group.items.map((item) => (
              <div data-achv-category={item.data.category}>
                <AchievementCard title={item.data.title} category={item.data.category} date={item.data.date} description={item.data.description} url={item.data.url} image={item.data.image} issuer={item.data.issuer} />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ============ TIMELINE VIEW ============ -->
    <div class="achv-view" id="achv-timeline-view" style="display:none;">
      <div class="achv-timeline">
        {timelineYears.map(year => (
          <div class="achv-tl-year-group" data-achv-year={year}>
            <div class="achv-tl-year-label">
              <span class="achv-tl-year-dot" aria-hidden="true"></span>
              <span class="achv-tl-year">{year}</span>
            </div>
            <div class="achv-tl-items">
              {byYear[year].sort((a, b) => a.data.order - b.data.order).map(item => {
                const cfg = categoryConfig[item.data.category];
                return (
                  <div class="achv-tl-item" data-achv-category={item.data.category}>
                    <div class="achv-tl-connector" aria-hidden="true">
                      <div class="achv-tl-line"></div>
                      <div class="achv-tl-dot" style={`background: ${cfg.color};`}></div>
                    </div>
                    <div class="achv-tl-card">
                      <div class="achv-tl-card-header">
                        <span class="achv-tl-cat-badge" style={`background: ${cfg.bgAlpha}; color: ${cfg.color};`}>
                          {cfg.icon} {cfg.label}
                        </span>
                        {item.data.date.length > 4 && (
                          <time class="achv-tl-date">{item.data.date}</time>
                        )}
                      </div>
                      <h3 class="achv-tl-title">
                        {item.data.url ? (
                          <a href={item.data.url} target="_blank" rel="noopener" class="achv-tl-link">
                            {item.data.title} <span aria-hidden="true">&nearr;</span>
                          </a>
                        ) : item.data.title}
                      </h3>
                      {item.data.issuer && (
                        <span class="achv-tl-issuer">{item.data.issuer}</span>
                      )}
                      <p class="achv-tl-desc">{item.data.description}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<!-- ======================== JS ======================== -->
<script>
  document.addEventListener('astro:page-load', () => {
    const page = document.getElementById('achievements-page');
    if (!page) return;

    // ---- View toggle ----
    const viewBtns = page.querySelectorAll<HTMLElement>('.achv-view-btn');
    const categoryView = document.getElementById('achv-category-view');
    const timelineView = document.getElementById('achv-timeline-view');

    viewBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        viewBtns.forEach(b => {
          b.classList.toggle('achv-view-btn--active', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });
        if (categoryView) categoryView.style.display = view === 'category' ? '' : 'none';
        if (timelineView) timelineView.style.display = view === 'timeline' ? '' : 'none';
      });
    });

    // ---- Category filter ----
    const filterBtns = page.querySelectorAll<HTMLElement>('[data-achv-filter]');
    const filterReset = document.getElementById('achv-filter-reset');
    const allCards = page.querySelectorAll<HTMLElement>('[data-achv-category]');
    const allGroups = page.querySelectorAll<HTMLElement>('[data-achv-group]');
    const allYearGroups = page.querySelectorAll<HTMLElement>('[data-achv-year]');
    let activeFilter: string | null = null;

    function resetFilter() {
      activeFilter = null;
      allCards.forEach(c => { c.style.display = ''; c.style.opacity = '1'; });
      allGroups.forEach(g => { g.style.display = ''; });
      allYearGroups.forEach(g => { g.style.display = ''; });
      filterBtns.forEach(b => b.classList.remove('achv-count-item--active'));
      if (filterReset) filterReset.style.display = 'none';
    }

    function applyFilter(cat: string) {
      if (activeFilter === cat) {
        resetFilter();
        return;
      }
      activeFilter = cat;

      allCards.forEach(c => {
        if (c.dataset.achvCategory === cat) {
          c.style.display = '';
          c.style.opacity = '1';
        } else {
          c.style.display = 'none';
        }
      });

      allGroups.forEach(g => {
        // 합쳐진 그룹(예: "patent-competition") 도 각 카테고리 필터에 보이도록 한다.
        const groupCats = (g.dataset.achvGroup || '').split('-');
        if (groupCats.includes(cat)) {
          g.style.display = '';
        } else {
          g.style.display = 'none';
        }
      });

      allYearGroups.forEach(g => {
        const items = g.querySelectorAll<HTMLElement>('[data-achv-category]');
        const hasVisible = Array.from(items).some(i => i.dataset.achvCategory === cat);
        g.style.display = hasVisible ? '' : 'none';
      });

      filterBtns.forEach(b => {
        b.classList.toggle('achv-count-item--active', b.dataset.achvFilter === cat);
      });

      if (filterReset) filterReset.style.display = '';
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.achvFilter || ''));
    });

    if (filterReset) {
      filterReset.addEventListener('click', resetFilter);
    }
  });
</script>

<!-- ======================== CSS ======================== -->
<style>
  /* ========= SUMMARY COUNT STRIP ========= */
  .achv-counts {
    display: flex;
    gap: 0.5rem;
    margin: 1.5rem 0 1rem;
    padding-left: 1.75rem;
    flex-wrap: wrap;
  }

  .achv-count-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-mono);
  }

  .achv-count-item:hover {
    border-color: var(--cat-color);
    background: color-mix(in srgb, var(--cat-color) 8%, transparent);
  }

  .achv-count-item--active {
    border-color: var(--cat-color);
    background: color-mix(in srgb, var(--cat-color) 12%, transparent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--cat-color) 20%, transparent);
  }

  .achv-count-icon { font-size: 0.875rem; }
  .achv-count-num {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--cat-color);
  }
  .achv-count-label {
    font-size: 0.625rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ========= VIEW TOGGLE + CONTROLS ========= */
  .achv-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-left: 1.75rem;
  }

  .achv-view-toggle {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .achv-view-btn {
    padding: 0.375rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .achv-view-btn:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .achv-view-btn--active {
    color: var(--color-accent-light);
    background: var(--color-bg-hover);
  }

  .achv-view-btn:hover:not(.achv-view-btn--active) {
    color: var(--color-text-secondary);
  }

  .achv-filter-reset {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .achv-filter-reset:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-light);
  }

  /* ========= HIGHLIGHT CARDS ========= */
  .achv-highlights {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .achv-highlight-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--hl-color) 30%, transparent);
    background: linear-gradient(135deg, var(--hl-bg), var(--color-bg-card));
    transition: all 0.3s;
  }

  .achv-highlight-card:hover {
    border-color: var(--hl-color);
    box-shadow: 0 0 20px color-mix(in srgb, var(--hl-color) 15%, transparent);
    transform: translateY(-2px);
  }

  .achv-hl-badge {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: var(--hl-bg);
    border: 1px solid color-mix(in srgb, var(--hl-color) 25%, transparent);
    font-size: 1.5rem;
  }

  .achv-hl-content { flex: 1; min-width: 0; }

  .achv-hl-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .achv-hl-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .achv-hl-title a:hover {
    color: var(--hl-color);
  }

  .achv-hl-ext { font-size: 0.75rem; opacity: 0.5; }

  .achv-hl-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  .achv-hl-desc {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* ========= CATEGORY GROUP HEADINGS ========= */
  .achv-group {
    margin-top: 2rem;
  }

  .achv-group-heading {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }

  .achv-group-icon-badge {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid;
    font-size: 1rem;
  }

  .achv-group-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .achv-group-count {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    padding: 1px 6px;
    border-radius: 9999px;
    background: var(--color-bg-secondary);
  }

  /* ========= TIMELINE VIEW ========= */
  .achv-timeline {
    position: relative;
    padding-left: 1rem;
  }

  .achv-tl-year-group {
    position: relative;
    margin-bottom: 2rem;
  }

  .achv-tl-year-group:last-child {
    margin-bottom: 0;
  }

  .achv-tl-year-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    position: relative;
  }

  .achv-tl-year-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-bg-primary);
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 2;
  }

  .achv-tl-year {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent-light);
  }

  .achv-tl-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-left: 0.375rem;
  }

  .achv-tl-item {
    display: flex;
    gap: 0;
  }

  .achv-tl-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 14px;
    flex-shrink: 0;
    position: relative;
  }

  .achv-tl-line {
    width: 2px;
    flex: 1;
    background: var(--color-border);
  }

  .achv-tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    position: absolute;
    top: 12px;
  }

  .achv-tl-card {
    flex: 1;
    padding: 0.75rem 1rem;
    margin-left: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition: all 0.2s;
  }

  .achv-tl-card:hover {
    border-color: var(--color-border-hover, var(--color-border));
    background: var(--color-bg-hover);
  }

  .achv-tl-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .achv-tl-cat-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 2px 8px;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
  }

  .achv-tl-date {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--color-text-muted);
  }

  .achv-tl-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
