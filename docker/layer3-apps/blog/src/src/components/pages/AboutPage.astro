---
import Layout from "../Layout.astro";
import Timeline from "../Timeline.astro";
import PageCTA from "../PageCTA.astro";
import profile from "../../data/profile.json";
import profileKo from "../../data/profile.ko.json";
import { t } from "../../i18n";

interface Props {
  locale: "ko" | "en";
}

const { locale } = Astro.props;

const layoutDescription = locale === "ko"
  ? "경력, 학력, 그리고 커리어 여정."
  : "Career background, education, and professional journey.";

const bhsnTitle = locale === "ko"
  ? "AI 엔지니어"
  : profile.currentRole.split(" at ")[0];
const bhsnOrg = locale === "ko"
  ? "BHSN"
  : profile.currentRole.split(" at ")[1];

const naverTitle = locale === "ko" ? "리서치 인턴" : "Research Intern";
const naverOrg = locale === "ko" ? "네이버 클라우드 (CLOVA)" : "Naver Cloud (CLOVA)";
const naverPeriod = locale === "ko" ? "2022.12 — 2023.02 (3개월)" : "2022.12 — 2023.02 (3 months)";

const militaryTitle = locale === "ko" ? "병역" : "Military Service";
const militaryOrg = locale === "ko" ? "대한민국 육군" : "Republic of Korea Army";

const eduProfile = locale === "ko" ? profileKo : profile;
---

<Layout title={t(locale, "about.title")} description={layoutDescription} locale={locale}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">{t(locale, "about.heading")}</h1>

    <!-- Profile -->
    <div class="mt-8 max-w-2xl space-y-4 text-base leading-relaxed text-[var(--color-text-secondary)]">
      <p>{t(locale, "about.bio1")}</p>
      <p>{t(locale, "about.bio2")}</p>
      <p>{t(locale, "about.bio3")}</p>
      <p>
        {t(locale, "about.bio4.prefix")}
        {" "}
        <a href="https://github.com/predibase/lorax" class="text-[var(--color-accent-light)] hover:underline" target="_blank" rel="noopener">predibase/lorax</a>{t(locale, "about.bio4.suffix")}
      </p>
    </div>

    <!-- Engineering Approach -->
    <div class="mt-12">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-4">{t(locale, "about.approach")}</h2>
      <p class="max-w-2xl text-base leading-relaxed text-[var(--color-text-secondary)]">{t(locale, "about.approach.text")}</p>
    </div>

    <!-- Key Strengths -->
    <div class="mt-12">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-4">{t(locale, "about.strengths")}</h2>
      <ul class="max-w-2xl space-y-2 text-base leading-relaxed text-[var(--color-text-secondary)]">
        <li class="flex gap-2"><span class="text-[var(--color-accent-light)] shrink-0">—</span>{t(locale, "about.strength1")}</li>
        <li class="flex gap-2"><span class="text-[var(--color-accent-light)] shrink-0">—</span>{t(locale, "about.strength2")}</li>
        <li class="flex gap-2"><span class="text-[var(--color-accent-light)] shrink-0">—</span>{t(locale, "about.strength3")}</li>
        <li class="flex gap-2"><span class="text-[var(--color-accent-light)] shrink-0">—</span>{t(locale, "about.strength4")}</li>
      </ul>
    </div>

    <!-- Career Timeline -->
    <div class="mt-16">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-8">{t(locale, "about.career")}</h2>
      <Timeline
        title={bhsnTitle}
        organization={bhsnOrg}
        period={`2023 — ${t(locale, "about.present")}`}
        current={true}
        description={t(locale, "about.career.bhsn")}
      />
      <Timeline
        title={naverTitle}
        organization={naverOrg}
        period={naverPeriod}
        description={t(locale, "about.career.naver")}
      />
      <Timeline
        title={militaryTitle}
        organization={militaryOrg}
        period="2020 — 2022"
        description={t(locale, "about.career.military")}
      />
    </div>

    <!-- Education -->
    <div class="mt-16">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-8">{t(locale, "about.education")}</h2>
      <Timeline
        title={eduProfile.education.degree}
        organization={eduProfile.education.school}
        period={eduProfile.education.period}
        description={`GPA: ${eduProfile.education.gpa} | ${eduProfile.education.honors.join(", ")}`}
      />
    </div>

    <PageCTA locale={locale} links={[
      { label: t(locale, "cta.viewProjects"), href: "/projects", primary: true },
      { label: t(locale, "cta.getInTouch"), href: "/contact" },
    ]} />
  </section>
</Layout>
