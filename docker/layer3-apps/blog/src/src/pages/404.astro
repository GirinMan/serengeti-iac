---
import Layout from "../components/Layout.astro";
import { localePath } from "../i18n";

const locale = "ko";

const links = [
  { label: "홈으로", href: "/", icon: "~" },
  { label: "프로젝트", href: "/projects", icon: ">" },
  { label: "경력", href: "/career", icon: ">" },
  { label: "연락처", href: "/contact", icon: ">" },
];
---

<Layout title="404 — 페이지를 찾을 수 없습니다" description="요청한 페이지를 찾을 수 없습니다." locale={locale}>
  <section class="mx-auto max-w-2xl px-6 py-24 flex flex-col items-center text-center">
    {/* Terminal-style 404 */}
    <div class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden">
      {/* Title bar */}
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
        <span class="ml-2 text-xs font-mono text-[var(--color-text-muted)]">girinman@career</span>
      </div>

      {/* Terminal body */}
      <div class="p-6 md:p-8 text-left font-mono text-sm leading-relaxed">
        <p class="text-[var(--color-terminal-green)]">
          <span class="opacity-60">$</span> cd /requested/page
        </p>
        <p class="mt-2 text-red-400">
          bash: cd: /requested/page: No such file or directory
        </p>
        <p class="mt-4 text-[var(--color-terminal-green)]">
          <span class="opacity-60">$</span> echo $?
        </p>
        <p class="mt-2 text-[var(--color-accent-light)]">
          404
        </p>
        <p class="mt-6 text-[var(--color-text-secondary)] font-sans text-base">
          요청한 페이지를 찾을 수 없습니다.
        </p>
        <p class="text-[var(--color-text-muted)] font-sans text-sm mt-1">
          The page you're looking for doesn't exist.
        </p>
      </div>
    </div>

    {/* Navigation links */}
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {links.map((link) => (
        <a
          href={localePath(locale, link.href)}
          class="group inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-4 py-2.5 text-sm font-mono text-[var(--color-text-secondary)] transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent-light)] hover:bg-[var(--color-accent)]/5"
        >
          <span class="text-[var(--color-accent)] opacity-60 group-hover:opacity-100 transition-opacity">{link.icon}</span>
          {link.label}
        </a>
      ))}
    </div>
  </section>
</Layout>
