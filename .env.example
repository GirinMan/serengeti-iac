# ===========================
# Network & Domain
# ===========================
CF_TUNNEL_TOKEN=<masked_tunnel_token>
CF_DOMAIN=<public_domain>
CF_BLOG_HOST=<blog_subdomain>
CF_NAS_HOST=<nas_subdomain>
CF_API_HOST=<api_subdomain>
CF_PLANE_HOST=<tasks_subdomain>
CF_SSH_HOST=<ssh_subdomain>
CF_S3_HOST=<object_storage_subdomain>

# ===========================
# Server & Access
# ===========================
SERVER_IP=<server_private_ip>
LOCAL_GW=<room_router_wan_ip>
LOCAL_SUBNET=<admin_subnet>
SSH_PORT=<ssh_port>
INITIAL_SSH_PORT=<initial_ssh_port>
SSH_USER=ubuntu
SSH_KEY_NAME=<ssh_key_name>
SSH_KEY_COMMENT=<ssh_key_comment>
TIMEZONE=Asia/Seoul
INSTALL_NVIDIA_TOOLKIT=false

# ===========================
# Host Ports
# ===========================
NPM_HTTP_PORT=<npm_http_port>
NPM_HTTPS_PORT=<npm_https_port>
NPM_ADMIN_PORT=<npm_admin_port>
WORDPRESS_VERSION=6.9.1-php8.2-apache
KAFKA_BROKER_PORT=<kafka_broker_port>
KAFKA_CONTROLLER_PORT=<kafka_controller_port>
MINIO_API_PORT=<minio_api_port>
MINIO_CONSOLE_PORT=<minio_console_port>

# ===========================
# Storage Devices
# ===========================
PRIMARY_STORAGE_ROOT=/mnt/primary
ARCHIVE_STORAGE_ROOT=/mnt/archive
DUMPS_DIR=/mnt/primary/dumps
ZFS_DISK1=/dev/disk/by-id/<zfs_disk1_id>
ZFS_DISK2=/dev/disk/by-id/<zfs_disk2_id>
PRIMARY_SSD_DISK=/dev/disk/by-id/<primary_ssd_disk_id>

# ===========================
# PostgreSQL
# ===========================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<masked_secret>
POSTGRES_DB=maindb

# ===========================
# Neo4j
# ===========================
NEO4J_VERSION=5.15-community
NEO4J_PASSWORD=<masked_secret>
NEO4J_AUTH=neo4j/<masked_secret>

# ===========================
# Elasticsearch
# ===========================
ES_VERSION=8.12.0
ES_JAVA_OPTS=-Xms512m -Xmx512m
ELASTIC_PASSWORD=<masked_secret>

# ===========================
# Redis
# ===========================
REDIS_VERSION=7-alpine
REDIS_PASSWORD=<masked_secret>

# ===========================
# RabbitMQ
# ===========================
RABBITMQ_VERSION=3.13.6-management-alpine
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=<masked_secret>
RABBITMQ_VHOST=plane

# ===========================
# Kafka KRaft
# ===========================
KAFKA_VERSION=3.9.2
KAFKA_CLUSTER_ID=<kafka_cluster_id>

# ===========================
# Minio
# ===========================
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=<masked_access_key>
MINIO_ROOT_PASSWORD=<masked_secret>

# ===========================
# WordPress Blog
# ===========================
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=<masked_secret>

# ===========================
# MariaDB
# ===========================
MARIADB_VERSION=11.4.7
MARIADB_ROOT_PASSWORD=<masked_secret>

# ===========================
# Nextcloud
# ===========================
NEXTCLOUD_VERSION=28-apache
NEXTCLOUD_ADMIN_USER=<admin_user>
NEXTCLOUD_ADMIN_PASSWORD=<masked_secret>
NEXTCLOUD_TRUSTED_DOMAINS=<nas_subdomain> <server_private_ip>

# ===========================
# Plane
# ===========================
PLANE_VERSION=v1.2.3
PLANE_DB_NAME=plane
PLANE_WEB_URL=https://<tasks_subdomain>
PLANE_API_BASE_URL=https://<tasks_subdomain>
PLANE_CORS_ALLOWED_ORIGINS=https://<tasks_subdomain>
PLANE_SECRET_KEY=<masked_secret>
PLANE_LIVE_SERVER_SECRET_KEY=<masked_secret>
PLANE_API_KEY_RATE_LIMIT=60/minute
PLANE_FILE_SIZE_LIMIT=5242880
PLANE_AWS_REGION=
PLANE_AWS_BUCKET_NAME=plane-uploads
PLANE_DATABASE_URL=postgresql://postgres:<masked_secret>@postgres:5432/plane
PLANE_AMQP_URL=amqp://plane:<masked_secret>@rabbitmq:5672/plane

# ===========================
# Backup
# ===========================
NEO4J_DATA_DIR=/mnt/primary/neo4j/data
BORG_REPO_HOST_PATH=/mnt/archive/borg-repo
BORG_PASSPHRASE=<masked_secret>
BORG_REPO=/borg-repo
